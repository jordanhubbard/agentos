/*
 * agentOS MsgBus — CAmkES Component Definition
 *
 * Defines the MsgBus as a CAmkES component with typed interfaces
 * for agent communication. Other components connect to MsgBus
 * via CAmkES connectors mapped to seL4 IPC.
 */

/* Interface: Channel management */
procedure ChannelIface {
    int create(in string name, in int flags);
    int delete(in string name);
    int subscribe(in string name, in int filter);
    int unsubscribe(in string name);
    int list(out string names, out int count);
};

/* Interface: Message passing */
procedure MessageIface {
    int publish(in string channel, in int msg_type, 
                in string payload, in int payload_len);
    int send_direct(in int dest_badge, in int msg_type,
                    in string payload, in int payload_len);
    int recv(in string channel, in int timeout_ms,
             out int msg_type, out string payload, out int payload_len);
};

/* Interface: RPC (synchronous call/reply) */
procedure RpcIface {
    int call(in int callee_badge, in string request, in int req_len,
             out string reply, out int reply_len, in int timeout_ms);
};

/* MsgBus component */
component MsgBus {
    provides ChannelIface channel;
    provides MessageIface message;
    provides RpcIface rpc;
    
    /* Internal: connection to CapStore for capability validation */
    uses CapValidation capstore;
    
    /* Internal: connection to LogSvc for audit logging */
    uses LogInterface logsvc;
}

/* Interface used by MsgBus to validate capabilities */
procedure CapValidation {
    int validate_cap(in int agent_badge, in int cap_type, in int operation);
};

/* Interface used for logging */
procedure LogInterface {
    void log_event(in int level, in string component, in string message);
};
