<?xml version="1.0" encoding="UTF-8"?>
<!--
  agentOS v0.4.0 System Description File (AArch64 + Linux VMM)
  
  Protection Domain topology:
  
    controller   (prio 50)   - system coordinator + capability broker
    event_bus    (prio 200)  - passive pub/sub server (ring buffer)
    init_agent   (prio 100)  - agent ecosystem bootstrapper
    worker_0..7  (prio 80)   - agent pool workers (dynamic task assignment)
    vibe_engine  (prio 140)  - passive VibeEngine: WASM hot-swap lifecycle
    agentfs      (prio 150)  - passive content-addressed object store
    swap_slot_0..3 (prio 75) - WASM hot-swap execution slots
    linux_vmm    (prio 254)  - Linux Virtual Machine Monitor (libvmm)
  
  Channel map (native agentOS — same as riscv64):
    0:  controller <-> event_bus    (controller PPCs into passive event_bus)
    1:  controller <-> init_agent   (notify: controller starts init_agent)
    2:  event_bus  <-> init_agent   (init_agent PPCs into event_bus to subscribe)
    5:  controller <-> agentfs      (controller PPCs into passive agentfs)
    6:  agentfs    <-> event_bus    (agentfs notifies on mutations)
    10: controller <-> worker_0     (task assignment + completion notify)
    11: controller <-> worker_1
    12: controller <-> worker_2
    13: controller <-> worker_3
    14: controller <-> worker_4
    15: controller <-> worker_5
    16: controller <-> worker_6
    17: controller <-> worker_7
    20..27: event_bus <-> worker_0..7  (workers subscribe to events)
    30..33: controller <-> swap_slot_0..3  (WASM hot-swap)
    40: controller <-> vibe_engine  (swap approval notification)
    41: init_agent <-> vibe_engine  (propose/validate/execute swaps)

  Linux VMM channels (new):
    50: controller <-> linux_vmm    (agent-to-linux bridge commands)
-->
<system>
    <!-- ═══════════════════════════════════════════════════════════════════
         NATIVE agentOS PROTECTION DOMAINS (identical to riscv64 build)
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- Controller: system coordinator, low priority to PPC into passive servers -->
    <protection_domain name="controller" priority="50">
        <program_image path="controller.elf" />
        <map mr="monitor_stack"  vaddr="0x2000000" perms="rw" setvar_vaddr="monitor_stack_vaddr" />
        <!-- Swap code regions: controller writes WASM images here; swap slot PDs read them -->
        <map mr="swap_code_0" vaddr="0x6000000" perms="rw" setvar_vaddr="swap_code_ctrl_0" />
        <map mr="swap_code_1" vaddr="0x6400000" perms="rw" setvar_vaddr="swap_code_ctrl_1" />
        <map mr="swap_code_2" vaddr="0x6800000" perms="rw" setvar_vaddr="swap_code_ctrl_2" />
        <map mr="swap_code_3" vaddr="0x6C00000" perms="rw" setvar_vaddr="swap_code_ctrl_3" />
        <!-- VibeEngine staging: controller reads WASM proposals from here (r) -->
        <map mr="vibe_staging" vaddr="0x7000000" perms="r" setvar_vaddr="vibe_staging_ctrl_vaddr" />
        <!-- cap_policy hot-reload: caller writes policy blob here before PPC -->
        <map mr="cap_policy_shmem" vaddr="0x7400000" perms="rw" setvar_vaddr="cap_policy_shmem_vaddr" />
        <!-- NameServer registry dump shmem: read after OP_NS_LIST call -->
        <map mr="ns_registry_shmem" vaddr="0xB000000" perms="r" setvar_vaddr="ns_registry_shmem_ctrl_vaddr" />
        <!-- VFS I/O shmem: request descriptor + path/data buffers -->
        <map mr="vfs_io_shmem"       vaddr="0xC000000"  perms="rw" setvar_vaddr="vfs_io_shmem_ctrl_vaddr" />
        <!-- SpawnServer ELF staging area -->
        <map mr="spawn_elf_shmem"    vaddr="0xD000000"  perms="rw" setvar_vaddr="spawn_elf_shmem_ctrl_vaddr" />
        <!-- Spawn config shmem: app name/path/list -->
        <map mr="spawn_config_shmem" vaddr="0xD100000"  perms="rw" setvar_vaddr="spawn_config_shmem_ctrl_vaddr" />
        <!-- Network packet shmem: vNIC ring headers + packet data -->
        <map mr="net_packet_shmem"   vaddr="0xE000000"  perms="r"  setvar_vaddr="net_packet_shmem_ctrl_vaddr" />
        <!-- HTTP request shmem: request header + body (observe only) -->
        <map mr="http_req_shmem"     vaddr="0xF000000"  perms="r"  setvar_vaddr="http_req_shmem_ctrl_vaddr" />
        <!-- App manifest shmem: controller writes manifests for AppManager -->
        <map mr="app_manifest_shmem" vaddr="0x10000000" perms="rw" setvar_vaddr="app_manifest_shmem_ctrl_vaddr" />
        <!-- block_shmem rw: controller writes data before MSG_BLOCK_WRITE,
             reads data after MSG_BLOCK_READ -->
        <map mr="block_shmem" vaddr="0x3500000" perms="rw" cached="true"
             setvar_vaddr="block_shmem_ctrl_vaddr" />
    </protection_domain>

    <!-- EventBus: passive pub/sub backbone -->
    <protection_domain name="event_bus" priority="200" passive="true">
        <program_image path="event_bus.elf" />
        <map mr="eventbus_ring" vaddr="0x3000000" perms="rw" setvar_vaddr="eventbus_ring_vaddr" />
    </protection_domain>
    
    <!-- InitAgent: bootstrap agent -->
    <protection_domain name="init_agent" priority="100">
        <program_image path="init_agent.elf" />
        <!-- js_staging: shared with js_runtime for script source/result exchange -->
        <map mr="js_staging" vaddr="0x7000000" perms="rw" />
    </protection_domain>
    
    <!-- Agent pool workers: static PDs, dynamic task assignment -->
    <protection_domain name="worker_0" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_1" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_2" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_3" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_4" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_5" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_6" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_7" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    
    <!-- AgentFS: passive object store, priority 150 -->
    <protection_domain name="agentfs" priority="150" passive="true">
        <program_image path="agentfs.elf" />
        <map mr="agentfs_store" vaddr="0x5000000" perms="rw" setvar_vaddr="agentfs_store_vaddr" />
    </protection_domain>

    <!-- VibeEngine: passive hot-swap lifecycle server -->
    <protection_domain name="vibe_engine" priority="140" passive="true">
        <program_image path="vibe_engine.elf" />
        <map mr="vibe_staging" vaddr="0x4000000" perms="rw" setvar_vaddr="vibe_staging_vaddr" />
    </protection_domain>

    <!-- Swap slots: 4 pre-allocated PDs for live WASM hot-swap -->
    <protection_domain name="swap_slot_0" priority="75">
        <program_image path="swap_slot.elf" />
        <map mr="swap_code_0" vaddr="0x2000000" perms="r" setvar_vaddr="swap_code_vaddr" />
    </protection_domain>
    <protection_domain name="swap_slot_1" priority="75">
        <program_image path="swap_slot.elf" />
        <map mr="swap_code_1" vaddr="0x2000000" perms="r" setvar_vaddr="swap_code_vaddr" />
    </protection_domain>
    <protection_domain name="swap_slot_2" priority="75">
        <program_image path="swap_slot.elf" />
        <map mr="swap_code_2" vaddr="0x2000000" perms="r" setvar_vaddr="swap_code_vaddr" />
    </protection_domain>
    <protection_domain name="swap_slot_3" priority="75">
        <program_image path="swap_slot.elf" />
        <map mr="swap_code_3" vaddr="0x2000000" perms="r" setvar_vaddr="swap_code_vaddr" />
    </protection_domain>

    <!-- ═══════════════════════════════════════════════════════════════════
         MEMORY REGIONS (native agentOS)
         ═══════════════════════════════════════════════════════════════════ -->
    <memory_region name="monitor_stack"    size="0x10000" />
    <memory_region name="eventbus_ring"    size="0x40000" />
    <memory_region name="cap_policy_shmem" size="0x1000" />
    <memory_region name="agentfs_store"    size="0x50000" />
    <memory_region name="swap_code_0"    size="0x400000" />
    <memory_region name="swap_code_1"    size="0x400000" />
    <memory_region name="swap_code_2"    size="0x400000" />
    <memory_region name="swap_code_3"    size="0x400000" />
    <memory_region name="vibe_staging"   size="0x400000" />

    <!-- ═══════════════════════════════════════════════════════════════════
         NATIVE agentOS CHANNELS (identical to riscv64 build)
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- Core service channels -->
    <channel>
        <end pd="controller" id="0" pp="true" />
        <end pd="event_bus"  id="0" />
    </channel>
    <channel>
        <end pd="controller" id="1" />
        <end pd="init_agent" id="1" />
    </channel>
    <channel>
        <end pd="event_bus"  id="2" />
        <end pd="init_agent" id="2" pp="true" />
    </channel>
    
    <!-- Controller <-> AgentFS -->
    <channel>
        <end pd="controller" id="5" pp="true" />
        <end pd="agentfs"    id="0" />
    </channel>
    <!-- AgentFS -> EventBus (mutation notifications) -->
    <channel>
        <end pd="agentfs"   id="1" />
        <end pd="event_bus" id="6" />
    </channel>

    <!-- Worker pool channels (controller <-> worker_N) -->
    <channel>
        <end pd="controller" id="10" />
        <end pd="worker_0"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="11" />
        <end pd="worker_1"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="12" />
        <end pd="worker_2"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="13" />
        <end pd="worker_3"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="14" />
        <end pd="worker_4"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="15" />
        <end pd="worker_5"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="16" />
        <end pd="worker_6"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="17" />
        <end pd="worker_7"   id="0" />
    </channel>

    <!-- Worker <-> EventBus channels -->
    <channel>
        <end pd="event_bus" id="20" />
        <end pd="worker_0"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="21" />
        <end pd="worker_1"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="22" />
        <end pd="worker_2"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="23" />
        <end pd="worker_3"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="24" />
        <end pd="worker_4"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="25" />
        <end pd="worker_5"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="26" />
        <end pd="worker_6"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="27" />
        <end pd="worker_7"  id="1" pp="true" />
    </channel>

    <!-- Controller <-> Swap slots -->
    <channel>
        <end pd="controller"  id="30" />
        <end pd="swap_slot_0" id="0" />
    </channel>
    <channel>
        <end pd="controller"  id="31" />
        <end pd="swap_slot_1" id="0" />
    </channel>
    <channel>
        <end pd="controller"  id="32" />
        <end pd="swap_slot_2" id="0" />
    </channel>
    <channel>
        <end pd="controller"  id="33" />
        <end pd="swap_slot_3" id="0" />
    </channel>

    <!-- VibeEngine channels -->
    <channel>
        <end pd="controller"   id="40" />
        <end pd="vibe_engine"  id="1" />
    </channel>
    <channel>
        <end pd="init_agent"   id="3" pp="true" />
        <end pd="vibe_engine"  id="0" />
    </channel>

    <!-- ═══════════════════════════════════════════════════════════════════
         LINUX VMM — Virtual Machine Monitor (AArch64 only)
         
         Uses au-ts/libvmm to boot a Linux guest inside agentOS.
         The VMM PD manages the guest lifecycle, handles faults,
         and bridges IPC between native agentOS agents and Linux.
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- Guest RAM: 256MB with 2MB large pages for efficiency -->
    <memory_region name="guest_ram" size="0x10_000_000" page_size="0x200_000" />

    <!-- UART: PL011 serial device, passed through to guest for direct I/O -->
    <memory_region name="serial" size="0x1_000" phys_addr="0x9000000" />

    <!-- GIC vCPU interface: hardware virtualisation of interrupt controller -->
    <memory_region name="gic_vcpu" size="0x1_000" phys_addr="0x8040000" />

    <protection_domain name="linux_vmm" priority="254">
        <program_image path="linux_vmm.elf" />
        <!--
            The VMM maps guest RAM at the same vaddr as the guest sees it
            (0x40000000). This is required by libvmm's current implementation.
        -->
        <map mr="guest_ram" vaddr="0x40000000" perms="rw" setvar_vaddr="guest_ram_vaddr" />

        <virtual_machine name="linux">
            <vcpu id="0" />
            <!-- Guest sees its RAM at 0x40000000 (matches DTS) -->
            <map mr="guest_ram" vaddr="0x40000000" perms="rwx" />
            <!-- Direct UART passthrough: guest can read/write serial without trapping -->
            <map mr="serial" vaddr="0x9000000" perms="rw" cached="false" />
            <!-- GIC vCPU interface mapped as if it were the real CPU interface -->
            <map mr="gic_vcpu" vaddr="0x8010000" perms="rw" cached="false" />
        </virtual_machine>

        <!--
            PL011 UART IRQ (SPI 1 + 32 = 33).
            Delivered to VMM as notification on channel 1,
            VMM injects it as virtual IRQ into the guest.
        -->
        <irq irq="33" id="1" />
    </protection_domain>

    <!-- Channel 50: controller <-> linux_vmm (agent-to-linux bridge) -->
    <channel>
        <end pd="controller" id="50" />
        <end pd="linux_vmm"  id="2" />
    </channel>

    <!-- ═══════════════════════════════════════════════════════════════════
         CONSOLE MULTIPLEXER — "tmux for agentOS"
         
         Passive PD (priority 160) that drains per-PD output rings to the debug UART.
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- Log drain ring buffer: 16 × 4KB = 64KB shared output rings -->
    <memory_region name="log_drain_rings" size="0x10000" />

    <protection_domain name="log_drain" priority="160" passive="true">
        <program_image path="log_drain.elf" />
        <map mr="log_drain_rings" vaddr="0x8000000" perms="rw" setvar_vaddr="log_drain_rings_vaddr" />
    </protection_domain>

    <!-- Channel 55: controller <-> log_drain (status queries) -->
    <channel>
        <end pd="controller"  id="55" pp="true" />
        <end pd="log_drain"   id="0" />
    </channel>

    <!-- Channel 56: init_agent <-> log_drain (output notifications) -->
    <channel>
        <end pd="init_agent"  id="4" />
        <end pd="log_drain"   id="1" />
    </channel>

    <!-- Channel 57: event_bus <-> log_drain (event activity notifications) -->
    <channel>
        <end pd="event_bus"   id="55" />
        <end pd="log_drain"   id="2" />
    </channel>

    <!-- Trace Recorder: passive stub, priority 128
         Channels 6-7 from controller's perspective:
           6: controller <-> trace_recorder (pp=true: START/STOP/QUERY/DUMP)
           7: controller -> trace_recorder  (notify on each inter-PD dispatch) -->
    <protection_domain name="trace_recorder" priority="128" passive="true">
        <program_image path="trace_recorder.elf" />
    </protection_domain>

    <channel>
        <end pd="controller"     id="6" pp="true" />
        <end pd="trace_recorder" id="0" />
    </channel>

    <channel>
        <end pd="controller"     id="7" />
        <end pd="trace_recorder" id="1" />
    </channel>

    <!-- NameServer: runtime service discovery (passive, prio 170) -->
    <memory_region name="ns_registry_shmem" size="0x2000" />

    <protection_domain name="nameserver" priority="170" passive="true">
        <program_image path="nameserver.elf" />
        <map mr="ns_registry_shmem" vaddr="0xB000000" perms="rw"
             setvar_vaddr="ns_registry_shmem_vaddr" />
    </protection_domain>

    <channel>
        <end pd="controller"  id="18" pp="true" />
        <end pd="nameserver"  id="0" />
    </channel>
    <channel>
        <end pd="init_agent"  id="7" pp="true" />
        <end pd="nameserver"  id="1" />
    </channel>
    <channel>
        <end pd="worker_0"   id="12" pp="true" />
        <end pd="nameserver" id="2" />
    </channel>
    <channel>
        <end pd="worker_1"   id="12" pp="true" />
        <end pd="nameserver" id="3" />
    </channel>
    <channel>
        <end pd="worker_2"   id="12" pp="true" />
        <end pd="nameserver" id="4" />
    </channel>
    <channel>
        <end pd="worker_3"   id="12" pp="true" />
        <end pd="nameserver" id="5" />
    </channel>
    <channel>
        <end pd="worker_4"   id="12" pp="true" />
        <end pd="nameserver" id="6" />
    </channel>
    <channel>
        <end pd="worker_5"   id="12" pp="true" />
        <end pd="nameserver" id="7" />
    </channel>
    <channel>
        <end pd="worker_6"   id="12" pp="true" />
        <end pd="nameserver" id="8" />
    </channel>
    <channel>
        <end pd="worker_7"   id="12" pp="true" />
        <end pd="nameserver" id="9" />
    </channel>

    <!--
      ══════════════════════════════════════════════════════════════════
      SERVICE LAYER: VFS, virtio-blk, SpawnServer, app slots,
                     NetServer, AppManager, HTTP service
      (Identical to riscv64 agentos.system)
      ══════════════════════════════════════════════════════════════════
    -->

    <memory_region name="vfs_io_shmem"       size="0x20000" />
    <memory_region name="blk_dma_shmem"      size="0x8000"  />
    <memory_region name="block_shmem"        size="0x10000" />
    <!-- QEMU virt MMIO: virtio-net bus.0 (aarch64: 0xa000000, 4KB page-aligned)
         Note: virtio-blk bus.1 is at 0xa000200 (same page) — cannot be mapped
         separately with page granularity; virtio_blk PD returns BLK_ERR_NODEV. -->
    <memory_region name="virtio_net_mmio"    size="0x1000"  phys_addr="0xa000000" />
    <memory_region name="spawn_elf_shmem"    size="0x80000" />
    <memory_region name="spawn_config_shmem" size="0x1000"  />
    <memory_region name="net_packet_shmem"   size="0x40000" />
    <memory_region name="app_manifest_shmem" size="0x4000"  />
    <memory_region name="http_req_shmem"     size="0x10000" />

    <protection_domain name="virtio_blk" priority="175" passive="true">
        <program_image path="virtio_blk.elf" />
        <map mr="blk_dma_shmem" vaddr="0x5000000" perms="rw"
             setvar_vaddr="blk_dma_shmem_vaddr" />
        <!-- blk_mmio_vaddr not mapped on aarch64: same page as net, returns BLK_ERR_NODEV -->
    </protection_domain>

    <channel>
        <end pd="controller"  id="22" pp="true" />
        <end pd="virtio_blk"  id="0" />
    </channel>

    <protection_domain name="vfs_server" priority="155" passive="true">
        <program_image path="vfs_server.elf" />
        <map mr="vfs_io_shmem"    vaddr="0x5000000" perms="rw"
             setvar_vaddr="vfs_io_shmem_vaddr" />
        <map mr="blk_dma_shmem"   vaddr="0x6000000" perms="rw"
             setvar_vaddr="blk_dma_shmem_vaddr" />
        <map mr="spawn_elf_shmem" vaddr="0x7000000" perms="rw"
             setvar_vaddr="spawn_elf_shmem_vfs_vaddr" />
    </protection_domain>

    <channel>
        <end pd="controller" id="19" pp="true" />
        <end pd="vfs_server" id="0" />
    </channel>
    <channel>
        <end pd="init_agent"  id="8" pp="true" />
        <end pd="vfs_server"  id="1" />
    </channel>
    <channel>
        <end pd="worker_0"   id="13" pp="true" />
        <end pd="vfs_server" id="2" />
    </channel>
    <channel>
        <end pd="worker_1"   id="13" pp="true" />
        <end pd="vfs_server" id="3" />
    </channel>
    <channel>
        <end pd="worker_2"   id="13" pp="true" />
        <end pd="vfs_server" id="4" />
    </channel>
    <channel>
        <end pd="worker_3"   id="13" pp="true" />
        <end pd="vfs_server" id="5" />
    </channel>
    <channel>
        <end pd="worker_4"   id="13" pp="true" />
        <end pd="vfs_server" id="6" />
    </channel>
    <channel>
        <end pd="worker_5"   id="13" pp="true" />
        <end pd="vfs_server" id="7" />
    </channel>
    <channel>
        <end pd="worker_6"   id="13" pp="true" />
        <end pd="vfs_server" id="8" />
    </channel>
    <channel>
        <end pd="worker_7"   id="13" pp="true" />
        <end pd="vfs_server" id="9" />
    </channel>
    <channel>
        <end pd="vfs_server" id="12" pp="true" />
        <end pd="virtio_blk" id="1" />
    </channel>

    <protection_domain name="spawn_server" priority="145">
        <program_image path="spawn_server.elf" />
        <map mr="spawn_elf_shmem"    vaddr="0x5000000" perms="rw"
             setvar_vaddr="spawn_elf_shmem_vaddr" />
        <map mr="spawn_config_shmem" vaddr="0x6000000" perms="rw"
             setvar_vaddr="spawn_config_shmem_vaddr" />
        <map mr="vfs_io_shmem"       vaddr="0x7000000" perms="rw"
             setvar_vaddr="vfs_io_shmem_vaddr" />
    </protection_domain>

    <channel>
        <end pd="controller"   id="20" pp="true" />
        <end pd="spawn_server" id="0" />
    </channel>
    <channel>
        <end pd="init_agent"   id="9" pp="true" />
        <end pd="spawn_server" id="1" />
    </channel>
    <channel>
        <end pd="spawn_server" id="3" pp="true" />
        <end pd="vfs_server"   id="10" />
    </channel>

    <protection_domain name="app_slot_0" priority="70">
        <program_image path="app_slot.elf" />
        <map mr="spawn_elf_shmem" vaddr="0x5000000" perms="r"
             setvar_vaddr="spawn_elf_shmem_vaddr" />
    </protection_domain>
    <protection_domain name="app_slot_1" priority="70">
        <program_image path="app_slot.elf" />
        <map mr="spawn_elf_shmem" vaddr="0x5000000" perms="r"
             setvar_vaddr="spawn_elf_shmem_vaddr" />
    </protection_domain>
    <protection_domain name="app_slot_2" priority="70">
        <program_image path="app_slot.elf" />
        <map mr="spawn_elf_shmem" vaddr="0x5000000" perms="r"
             setvar_vaddr="spawn_elf_shmem_vaddr" />
    </protection_domain>
    <protection_domain name="app_slot_3" priority="70">
        <program_image path="app_slot.elf" />
        <map mr="spawn_elf_shmem" vaddr="0x5000000" perms="r"
             setvar_vaddr="spawn_elf_shmem_vaddr" />
    </protection_domain>

    <channel>
        <end pd="spawn_server" id="4" />
        <end pd="app_slot_0"   id="0" />
    </channel>
    <channel>
        <end pd="spawn_server" id="5" />
        <end pd="app_slot_1"   id="0" />
    </channel>
    <channel>
        <end pd="spawn_server" id="6" />
        <end pd="app_slot_2"   id="0" />
    </channel>
    <channel>
        <end pd="spawn_server" id="7" />
        <end pd="app_slot_3"   id="0" />
    </channel>

    <protection_domain name="net_server" priority="160" passive="true">
        <program_image path="net_server.elf" />
        <map mr="net_packet_shmem"  vaddr="0x5000000" perms="rw"
             setvar_vaddr="net_packet_shmem_vaddr" />
        <map mr="virtio_net_mmio"   vaddr="0x6000000" perms="rw" cached="false"
             setvar_vaddr="net_mmio_vaddr" />
        <!-- Staging region: shared with vibe_engine for HTTP POST request/response bodies -->
        <map mr="vibe_staging" vaddr="0x9000000" perms="rw"
             setvar_vaddr="vibe_staging_vaddr" />
    </protection_domain>

    <channel>
        <end pd="controller" id="21" pp="true" />
        <end pd="net_server" id="0" />
    </channel>
    <channel>
        <end pd="init_agent"  id="10" pp="true" />
        <end pd="net_server"  id="1" />
    </channel>
    <channel>
        <end pd="worker_0"   id="14" pp="true" />
        <end pd="net_server" id="2" />
    </channel>
    <channel>
        <end pd="worker_1"   id="14" pp="true" />
        <end pd="net_server" id="3" />
    </channel>
    <channel>
        <end pd="worker_2"   id="14" pp="true" />
        <end pd="net_server" id="4" />
    </channel>
    <channel>
        <end pd="worker_3"   id="14" pp="true" />
        <end pd="net_server" id="5" />
    </channel>
    <channel>
        <end pd="worker_4"   id="14" pp="true" />
        <end pd="net_server" id="6" />
    </channel>
    <channel>
        <end pd="worker_5"   id="14" pp="true" />
        <end pd="net_server" id="7" />
    </channel>
    <channel>
        <end pd="worker_6"   id="14" pp="true" />
        <end pd="net_server" id="8" />
    </channel>
    <channel>
        <end pd="worker_7"   id="14" pp="true" />
        <end pd="net_server" id="9" />
    </channel>

    <protection_domain name="app_manager" priority="130">
        <program_image path="app_manager.elf" />
        <map mr="app_manifest_shmem"  vaddr="0x5000000" perms="rw"
             setvar_vaddr="app_manifest_shmem_vaddr" />
        <map mr="spawn_config_shmem"  vaddr="0x8000000" perms="rw"
             setvar_vaddr="spawn_config_shmem_appmgr_vaddr" />
        <map mr="vfs_io_shmem"        vaddr="0x9000000" perms="rw"
             setvar_vaddr="vfs_io_shmem_appmgr_vaddr" />
    </protection_domain>

    <channel>
        <end pd="controller"  id="23" pp="true" />
        <end pd="app_manager" id="0" />
    </channel>
    <channel>
        <end pd="app_manager"  id="1" pp="true" />
        <end pd="spawn_server" id="2" />
    </channel>
    <channel>
        <end pd="app_manager" id="2" pp="true" />
        <end pd="vfs_server"  id="11" />
    </channel>
    <channel>
        <end pd="app_manager" id="3" pp="true" />
        <end pd="net_server"  id="10" />
    </channel>

    <protection_domain name="http_svc" priority="140">
        <program_image path="http_svc.elf" />
        <map mr="http_req_shmem" vaddr="0x5000000" perms="rw"
             setvar_vaddr="http_req_shmem_vaddr" />
    </protection_domain>

    <channel>
        <end pd="controller" id="24" pp="true" />
        <end pd="http_svc"   id="0" />
    </channel>
    <channel>
        <end pd="app_manager" id="4" pp="true" />
        <end pd="http_svc"    id="1" />
    </channel>

    <!-- ═══════════════════════════════════════════════════════════════════
         JS RUNTIME — JavaScript execution sandbox (passive, prio 120)

         Passive PD that provides a sandboxed JavaScript runtime for
         agent scripts. Shares a 4MB staging buffer with init_agent
         for script source and result exchange.
         ═══════════════════════════════════════════════════════════════════ -->

    <memory_region name="js_staging" size="0x400000" />

    <protection_domain name="js_runtime" priority="120" passive="true">
        <program_image path="js_runtime.elf" />
        <map mr="js_staging" vaddr="0x7000000" perms="rw"
             setvar_vaddr="js_staging_vaddr" />
    </protection_domain>

    <!-- Channel 60: controller <-> js_runtime (ch 0 on js_runtime side) -->
    <channel>
        <end pd="controller"  id="60" pp="true" />
        <end pd="js_runtime"  id="0" />
    </channel>

    <!-- Channel 61: init_agent <-> js_runtime (ch 1 on js_runtime side) -->
    <channel>
        <end pd="init_agent"  id="11" pp="true" />
        <end pd="js_runtime"  id="1" />
    </channel>

    <!-- js_staging mapped into init_agent for script source/result exchange -->
    <!-- init_agent maps js_staging at 0x7000000 (rw) via setvar_vaddr js_staging_vaddr -->
    <!-- Note: init_agent maps js_staging at the same vaddr as js_runtime sees it -->

    <!-- ═══════════════════════════════════════════════════════════════════
         WG_NET — WireGuard network tunnel PD (passive, prio 140)

         Passive PD that implements WireGuard tunnel management.
         Bridges controller commands to net_server for encrypted
         peer-to-peer networking.
         ═══════════════════════════════════════════════════════════════════ -->

    <memory_region name="wg_staging" size="0x100000" />

    <protection_domain name="wg_net" priority="140" passive="true">
        <program_image path="wg_net.elf" />
        <map mr="wg_staging" vaddr="0x8000000" perms="rw"
             setvar_vaddr="wg_staging_vaddr" />
    </protection_domain>

    <!-- Channel 62: controller <-> wg_net (ch 0 on wg_net side) -->
    <channel>
        <end pd="controller" id="61" pp="true" />
        <end pd="wg_net"     id="0" />
    </channel>

    <!-- Channel 63: wg_net <-> net_server (ch 1 on wg_net side) -->
    <channel>
        <end pd="wg_net"     id="1" pp="true" />
        <end pd="net_server" id="11" />
    </channel>

    <!-- controller lwIP timer tick -> net_server (NET_CH_TIMER=12) -->
    <channel>
        <end pd="controller"  id="59" />
        <end pd="net_server"  id="12" />
    </channel>

    <!-- ═══════════════════════════════════════════════════════════════════
         CONSOLE SHELL — interactive management console (priority 80)

         On QEMU dev mode: reads commands from console_shell_ring (4KB
         shared memory with bridge.rs); emits VM start/stop escape
         sequences to the debug serial port.  The PL011 IRQ (33) is
         owned by linux_vmm for guest passthrough so console_shell runs
         in ring-buffer mode only on QEMU aarch64 — no UART MR or IRQ
         is registered here.

         On native RPi5/NUC hardware a separate board-specific system
         file (boards/<board>/agentos.system) maps the physical UART MR
         and wires CH_UART_IRQ (channel 3) to the correct GIC line.
         ═══════════════════════════════════════════════════════════════════ -->

    <memory_region name="console_shell_ring" size="0x1000" />

    <protection_domain name="console_shell" priority="49">
        <program_image path="console_shell.elf" />
        <!-- Ring buffer shared with bridge.rs for dev-mode IPC -->
        <map mr="console_shell_ring" vaddr="0x5100000" perms="rw"
             setvar_vaddr="console_shell_ring_vaddr" />
    </protection_domain>

    <!-- controller notifies console_shell of VM state changes -->
    <channel>
        <end pd="controller"    id="41" />
        <end pd="console_shell" id="0" />
    </channel>
    <!-- console_shell PPCs controller for VM management (native HW path) -->
    <channel>
        <end pd="console_shell" id="1" pp="true" />
        <end pd="controller"    id="42" />
    </channel>

    <!--
      block_pd: OS-neutral block device service PD (passive, prio 165)
      Channels:
        id=0: callers PPC in (MSG_BLOCK_*)
        id=1: block_pd PPCs out to virtio_blk (OP_BLK_*)
    -->
    <protection_domain name="block_pd" priority="165" passive="true">
        <program_image path="block_pd.elf" />
        <map mr="block_shmem"  vaddr="0x5000000" perms="rw" cached="true"
             setvar_vaddr="block_shmem_vaddr" />
        <map mr="blk_dma_shmem" vaddr="0x6000000" perms="rw" cached="false"
             setvar_vaddr="blk_dma_shmem_vaddr" />
    </protection_domain>

    <!-- Channel CH_BLOCK_PD (69): controller → block_pd -->
    <channel>
        <end pd="controller" id="69" pp="true" />
        <end pd="block_pd"   id="0" />
    </channel>

    <!-- Channel: block_pd → virtio_blk (block_pd forwards I/O via OP_BLK_*) -->
    <channel>
        <end pd="block_pd"   id="1" pp="true" />
        <end pd="virtio_blk" id="3" />
    </channel>

</system>
