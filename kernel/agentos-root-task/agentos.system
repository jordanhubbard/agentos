<?xml version="1.0" encoding="UTF-8"?>
<!--
  agentOS v0.3.0 System Description File
  
  Protection Domain topology:
  
    controller   (prio 50)   - system coordinator + capability broker
    event_bus    (prio 200)  - passive pub/sub server (ring buffer)
    init_agent   (prio 100)  - agent ecosystem bootstrapper
    worker_0..7  (prio 80)   - agent pool workers (dynamic task assignment)
    vibe_engine  (prio 140)  - passive VibeEngine: WASM hot-swap lifecycle
    console_mux  (prio 160)  - passive session multiplexer ("tmux for agents")
    trace_recorder (prio 128) - passive inter-PD dispatch event logger (stub)
    mem_profiler (prio 108)  - passive heap alloc tracker + leak detector
    net_isolator (prio 160)  - passive per-agent outbound network firewall
  
  Channel map:
    0:  controller <-> event_bus    (controller PPCs into passive event_bus)
    1:  controller <-> init_agent   (notify: controller starts init_agent)
    2:  event_bus  <-> init_agent   (init_agent PPCs into event_bus to subscribe)
    5:  controller <-> agentfs        (controller PPCs into passive agentfs)
    6:  controller <-> trace_recorder (PPC: START/STOP/QUERY/DUMP)
    7:  controller -> trace_recorder  (notify on each inter-PD dispatch)
    10: controller <-> worker_0     (task assignment + completion notify)
    11: controller <-> worker_1
    12: controller <-> worker_2
    13: controller <-> worker_3
    14: controller <-> worker_4
    15: controller <-> worker_5
    16: controller <-> worker_6
    17: controller <-> worker_7
    
  Worker <-> EventBus channels (workers subscribe to events):
    20: event_bus <-> worker_0
    21: event_bus <-> worker_1
    ...
    27: event_bus <-> worker_7
    30: controller <-> swap_slot_0  (WASM hot-swap)
    31: controller <-> swap_slot_1
    32: controller <-> swap_slot_2
    33: controller <-> swap_slot_3

  VibeEngine channels:
    40: controller <-> vibe_engine  (vibe_engine notifies controller: swap approved)
    41: init_agent <-> vibe_engine  (init_agent PPCs into vibe_engine to propose swaps)

  Console Multiplexer channels:
    60: controller   <-> console_mux  (attach/detach/list/mode commands)
    61: init_agent   <-> console_mux  (init_agent output)
    62: event_bus    <-> console_mux  (eventbus output notification)

  Network Isolator channels:
    63: controller   <-> net_isolator  (pp=true: CONNECT check, STATUS query)
    64: init_agent   <-> net_isolator  (pp=true: ACL_SET on spawn, ACL_CLEAR on teardown)
    65: net_isolator <-> event_bus     (deny event notifications)
-->
<system>
    <!-- Controller: system coordinator, low priority to PPC into passive servers -->
    <protection_domain name="controller" priority="50">
        <program_image path="controller.elf" />
        <map mr="monitor_stack"  vaddr="0x2000000" perms="rw" setvar_vaddr="monitor_stack_vaddr" />
        <!-- Swap code regions: controller writes WASM images here; swap slot PDs read them -->
        <map mr="swap_code_0" vaddr="0x6000000" perms="rw" setvar_vaddr="swap_code_ctrl_0" />
        <map mr="swap_code_1" vaddr="0x6400000" perms="rw" setvar_vaddr="swap_code_ctrl_1" />
        <map mr="swap_code_2" vaddr="0x6800000" perms="rw" setvar_vaddr="swap_code_ctrl_2" />
        <map mr="swap_code_3" vaddr="0x6C00000" perms="rw" setvar_vaddr="swap_code_ctrl_3" />
        <!-- VibeEngine staging: controller reads WASM proposals from here (r) -->
        <map mr="vibe_staging" vaddr="0x7000000" perms="r" setvar_vaddr="vibe_staging_ctrl_vaddr" />
        <!-- cap_policy hot-reload: caller writes policy blob here before PPC -->
        <map mr="cap_policy_shmem" vaddr="0x7400000" perms="rw" setvar_vaddr="cap_policy_shmem_vaddr" />
        <!-- NameServer registry dump: controller reads after OP_NS_LIST call -->
        <map mr="ns_registry_shmem" vaddr="0xB000000" perms="r" setvar_vaddr="ns_registry_shmem_ctrl_vaddr" />
        <!-- VFS I/O shmem: request descriptor + path/data buffers -->
        <map mr="vfs_io_shmem"       vaddr="0xC000000"  perms="rw" setvar_vaddr="vfs_io_shmem_ctrl_vaddr" />
        <!-- SpawnServer ELF staging area -->
        <map mr="spawn_elf_shmem"    vaddr="0xD000000"  perms="rw" setvar_vaddr="spawn_elf_shmem_ctrl_vaddr" />
        <!-- Spawn config shmem: app name/path/list -->
        <map mr="spawn_config_shmem" vaddr="0xD100000"  perms="rw" setvar_vaddr="spawn_config_shmem_ctrl_vaddr" />
        <!-- Network packet shmem: vNIC ring headers + packet data -->
        <map mr="net_packet_shmem"   vaddr="0xE000000"  perms="r"  setvar_vaddr="net_packet_shmem_ctrl_vaddr" />
        <!-- HTTP request shmem: request header + body (observe only) -->
        <map mr="http_req_shmem"     vaddr="0xF000000"  perms="r"  setvar_vaddr="http_req_shmem_ctrl_vaddr" />
        <!-- App manifest shmem: controller writes manifests for AppManager -->
        <map mr="app_manifest_shmem" vaddr="0x10000000" perms="rw" setvar_vaddr="app_manifest_shmem_ctrl_vaddr" />
    </protection_domain>
    
    <!-- EventBus: passive pub/sub backbone -->
    <protection_domain name="event_bus" priority="200" passive="true">
        <program_image path="event_bus.elf" />
        <map mr="eventbus_ring" vaddr="0x3000000" perms="rw" setvar_vaddr="eventbus_ring_vaddr" />
    </protection_domain>
    
    <!-- InitAgent: bootstrap agent -->
    <protection_domain name="init_agent" priority="100">
        <program_image path="init_agent.elf" />
    </protection_domain>
    
    <!-- Agent pool workers: static PDs, dynamic task assignment -->
    <protection_domain name="worker_0" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_1" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_2" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_3" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_4" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_5" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_6" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_7" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    
    <!-- Memory regions -->
    <memory_region name="monitor_stack"   size="0x10000" />
    <memory_region name="eventbus_ring"   size="0x40000" />
    <memory_region name="cap_policy_shmem" size="0x1000" />
    
    <!-- Core service channels -->
    <channel>
        <end pd="controller" id="0" pp="true" />
        <end pd="event_bus"  id="0" />
    </channel>
    <channel>
        <end pd="controller" id="1" />
        <end pd="init_agent" id="1" />
    </channel>
    <channel>
        <end pd="event_bus"  id="2" />
        <end pd="init_agent" id="2" pp="true" />
    </channel>
    
    <!-- Worker pool channels (controller <-> worker_N) -->
    <channel>
        <end pd="controller" id="10" />
        <end pd="worker_0"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="11" />
        <end pd="worker_1"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="12" />
        <end pd="worker_2"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="13" />
        <end pd="worker_3"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="14" />
        <end pd="worker_4"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="15" />
        <end pd="worker_5"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="16" />
        <end pd="worker_6"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="17" />
        <end pd="worker_7"   id="0" />
    </channel>
    
    <!-- AgentFS: passive object store, priority 150 -->
    <!-- Channels: CH0=controller (PPC in), CH1=event_bus (notify out) -->
    <protection_domain name="agentfs" priority="150" passive="true">
        <program_image path="agentfs.elf" />
        <map mr="agentfs_store" vaddr="0x5000000" perms="rw" setvar_vaddr="agentfs_store_vaddr" />
    </protection_domain>

    <!-- Shared memory for AgentFS hot store -->
    <memory_region name="agentfs_store" size="0x50000" />  <!-- 320KB: index + blobs -->

    <!-- Channel 5: controller <-> agentfs (controller PPCs into passive agentfs) -->
    <channel>
        <end pd="controller" id="5" pp="true" />
        <end pd="agentfs"    id="0" />
    </channel>
    <!-- Channel 6: agentfs -> event_bus (agentfs notifies on mutations) -->
    <channel>
        <end pd="agentfs"   id="1" />
        <end pd="event_bus" id="6" />
    </channel>

    <!-- Worker <-> EventBus channels (workers can subscribe to events) -->
    <channel>
        <end pd="event_bus" id="20" />
        <end pd="worker_0"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="21" />
        <end pd="worker_1"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="22" />
        <end pd="worker_2"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="23" />
        <end pd="worker_3"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="24" />
        <end pd="worker_4"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="25" />
        <end pd="worker_5"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="26" />
        <end pd="worker_6"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="27" />
        <end pd="worker_7"  id="1" pp="true" />
    </channel>

    <!--
      Swap slots: 4 pre-allocated PDs for live WASM hot-swap.
      Controller maps each code region rw (writes WASM image + header).
      Swap slot maps it r (reads and interprets via wasm3).
      Channels: controller id=30..33 <-> swap_slot_N id=0
    -->
    <memory_region name="swap_code_0" size="0x400000" />
    <memory_region name="swap_code_1" size="0x400000" />
    <memory_region name="swap_code_2" size="0x400000" />
    <memory_region name="swap_code_3" size="0x400000" />

    <protection_domain name="swap_slot_0" priority="75">
        <program_image path="swap_slot.elf" />
        <map mr="swap_code_0" vaddr="0x2000000" perms="r" setvar_vaddr="swap_code_vaddr" />
    </protection_domain>
    <protection_domain name="swap_slot_1" priority="75">
        <program_image path="swap_slot.elf" />
        <map mr="swap_code_1" vaddr="0x2000000" perms="r" setvar_vaddr="swap_code_vaddr" />
    </protection_domain>
    <protection_domain name="swap_slot_2" priority="75">
        <program_image path="swap_slot.elf" />
        <map mr="swap_code_2" vaddr="0x2000000" perms="r" setvar_vaddr="swap_code_vaddr" />
    </protection_domain>
    <protection_domain name="swap_slot_3" priority="75">
        <program_image path="swap_slot.elf" />
        <map mr="swap_code_3" vaddr="0x2000000" perms="r" setvar_vaddr="swap_code_vaddr" />
    </protection_domain>

    <!-- Channels: controller <-> swap slots -->
    <channel>
        <end pd="controller"  id="30" />
        <end pd="swap_slot_0" id="0" />
    </channel>
    <channel>
        <end pd="controller"  id="31" />
        <end pd="swap_slot_1" id="0" />
    </channel>
    <channel>
        <end pd="controller"  id="32" />
        <end pd="swap_slot_2" id="0" />
    </channel>
    <channel>
        <end pd="controller"  id="33" />
        <end pd="swap_slot_3" id="0" />
    </channel>

    <!--
      VibeEngine: passive hot-swap lifecycle server (priority 140)

      Channels:
        id=0: agents PPC in to propose/validate/execute swaps
        id=1: vibe_engine notifies controller when a swap is approved

      Shared memory:
        vibe_staging (4MB): WASM binary staging area
          - Agents write WASM bytes here before calling OP_VIBE_PROPOSE
          - VibeEngine reads + validates
          - Controller reads and feeds to vibe_swap_begin
    -->
    <memory_region name="vibe_staging" size="0x400000" />  <!-- 4MB staging -->

    <protection_domain name="vibe_engine" priority="140" passive="true">
        <program_image path="vibe_engine.elf" />
        <!-- rw: vibe_engine reads staged WASM and writes metadata footer -->
        <map mr="vibe_staging" vaddr="0x4000000" perms="rw" setvar_vaddr="vibe_staging_vaddr" />
    </protection_domain>

    <!--
      Channel 40: controller(id=40) <-> vibe_engine(id=1)
      vibe_engine notifies controller when a swap proposal is approved.
      Controller wakes up, reads staging metadata, calls vibe_swap_begin.
    -->
    <channel>
        <end pd="controller"   id="40" />
        <end pd="vibe_engine"  id="1" />
    </channel>

    <!--
      Channel 41: init_agent(id=3) <-> vibe_engine(id=0) pp=true
      init_agent can PPC into vibe_engine to propose/validate/execute swaps.
      Used by the demo sequence (Step 4: hot-swap toolsvc with echo_service.wasm).
    -->
    <channel>
        <end pd="init_agent"   id="3" pp="true" />
        <end pd="vibe_engine"  id="0" />
    </channel>

    <!--
      MemProfiler: passive WASM heap allocation tracker (priority 108)

      Tracks per-slot live alloc count + bytes. Workers call
      OP_MEM_ALLOC_HOOK / OP_MEM_FREE_HOOK via PPC. Controller sends
      tick notifications every scheduling quantum; mem_profiler writes
      heap snapshots into the 256KB mem_ring every 30 ticks and fires
      OP_MEM_LEAK_ALERT to the controller if a slot shows 100 consecutive
      ticks of monotonically growing live allocation count.

      Channels:
        id=0: controller <-> mem_profiler
              - controller notifies (tick); mem_profiler PPCs (leak alert)
        id=1..8: worker_0..7 <-> mem_profiler (pp=true: workers PPC in)

      Shared memory:
        mem_ring (256KB): ring buffer of 64-byte per-slot heap snapshots
    -->

    <memory_region name="mem_ring" size="0x40000" />   <!-- 256KB snapshot ring -->

    <protection_domain name="mem_profiler" priority="108" passive="true">
        <program_image path="mem_profiler.elf" />
        <map mr="mem_ring" vaddr="0x8000000" perms="rw" setvar_vaddr="mem_ring_vaddr" />
    </protection_domain>

    <!-- Channel 50: controller(id=50) <-> mem_profiler(id=0)
         Controller notifies mem_profiler for each tick.
         mem_profiler PPCs controller for leak alerts. -->
    <channel>
        <end pd="controller"    id="50" />
        <end pd="mem_profiler"  id="0" />
    </channel>

    <!-- Channels 51–58: worker_N(id=9) <-> mem_profiler(id=1..8) pp=true
         Workers PPC into mem_profiler for alloc/free hook recording. -->
    <channel>
        <end pd="worker_0"     id="9" pp="true" />
        <end pd="mem_profiler" id="1" />
    </channel>
    <channel>
        <end pd="worker_1"     id="9" pp="true" />
        <end pd="mem_profiler" id="2" />
    </channel>
    <channel>
        <end pd="worker_2"     id="9" pp="true" />
        <end pd="mem_profiler" id="3" />
    </channel>
    <channel>
        <end pd="worker_3"     id="9" pp="true" />
        <end pd="mem_profiler" id="4" />
    </channel>
    <channel>
        <end pd="worker_4"     id="9" pp="true" />
        <end pd="mem_profiler" id="5" />
    </channel>
    <channel>
        <end pd="worker_5"     id="9" pp="true" />
        <end pd="mem_profiler" id="6" />
    </channel>
    <channel>
        <end pd="worker_6"     id="9" pp="true" />
        <end pd="mem_profiler" id="7" />
    </channel>
    <channel>
        <end pd="worker_7"     id="9" pp="true" />
        <end pd="mem_profiler" id="8" />
    </channel>

    <!--
      ══════════════════════════════════════════════════════════════════
      TimePartition: seL4 MCS time-partitioning scheduler (passive, prio 250)

      Highest user-space priority (250). Enforces fixed CPU budget windows
      per agent class via seL4 SchedContext manipulation.

      Defaults: gpu_worker(5ms/10ms), mesh_agent(2ms/10ms), watchdog(1ms/5ms).
      Override via OP_TP_SET_POLICY at runtime or cap_policy DSL.

      Channels (90–99):
        90: controller(id=90, pp=true) <-> time_partition(id=0)
        91..98: worker_0..7(id=11, pp=true) <-> time_partition(id=1..8)
        99: init_agent(id=5, pp=true) <-> time_partition(id=9)
      ══════════════════════════════════════════════════════════════════
    -->

    <protection_domain name="time_partition" priority="250" passive="true">
        <program_image path="time_partition.elf" />
    </protection_domain>

    <!-- Channel 41: controller(id=41, pp=true) <-> time_partition(id=0) -->
    <channel>
        <end pd="controller"     id="41" pp="true" />
        <end pd="time_partition" id="0" />
    </channel>

    <!-- Channels 91–98: worker_N(id=11, pp=true) <-> time_partition(id=1..8) -->
    <channel>
        <end pd="worker_0"       id="11" pp="true" />
        <end pd="time_partition" id="1" />
    </channel>
    <channel>
        <end pd="worker_1"       id="11" pp="true" />
        <end pd="time_partition" id="2" />
    </channel>
    <channel>
        <end pd="worker_2"       id="11" pp="true" />
        <end pd="time_partition" id="3" />
    </channel>
    <channel>
        <end pd="worker_3"       id="11" pp="true" />
        <end pd="time_partition" id="4" />
    </channel>
    <channel>
        <end pd="worker_4"       id="11" pp="true" />
        <end pd="time_partition" id="5" />
    </channel>
    <channel>
        <end pd="worker_5"       id="11" pp="true" />
        <end pd="time_partition" id="6" />
    </channel>
    <channel>
        <end pd="worker_6"       id="11" pp="true" />
        <end pd="time_partition" id="7" />
    </channel>
    <channel>
        <end pd="worker_7"       id="11" pp="true" />
        <end pd="time_partition" id="8" />
    </channel>

    <!-- Channel 99: init_agent(id=5, pp=true) <-> time_partition(id=9) -->
    <channel>
        <end pd="init_agent"     id="5" pp="true" />
        <end pd="time_partition" id="9" />
    </channel>

    <!--
      ══════════════════════════════════════════════════════════════════
      PerfCounters: continuous IPC latency histograms (passive, prio 95)

      Every PD that makes PPC calls wraps them with OP_PERF_BEGIN/END
      (via PERF_PPC macro in agentos.h) to record per-pair latencies.

      Channels (70–78):
        70: controller(id=70, pp=true) <-> perf_counters(id=0)
        71..78: worker_0..7(id=10, pp=true) <-> perf_counters(id=1..8)

      Shared memory:
        perf_ring (4KB): packed 64-byte export records per PD pair.
        Written on OP_PERF_EXPORT; read by metrics_exporter or Grafana.
      ══════════════════════════════════════════════════════════════════
    -->

    <memory_region name="perf_ring" size="0x1000" />   <!-- 4KB: 64 × 64B records -->

    <protection_domain name="perf_counters" priority="95" passive="true">
        <program_image path="perf_counters.elf" />
        <map mr="perf_ring" vaddr="0xA000000" perms="rw" setvar_vaddr="perf_ring_vaddr" />
    </protection_domain>

    <!-- Channel 42: controller(id=42, pp=true) <-> perf_counters(id=0) -->
    <channel>
        <end pd="controller"    id="42" pp="true" />
        <end pd="perf_counters" id="0" />
    </channel>

    <!-- Channels 71–78: worker_N(id=10, pp=true) <-> perf_counters(id=1..8) -->
    <channel>
        <end pd="worker_0"      id="10" pp="true" />
        <end pd="perf_counters" id="1" />
    </channel>
    <channel>
        <end pd="worker_1"      id="10" pp="true" />
        <end pd="perf_counters" id="2" />
    </channel>
    <channel>
        <end pd="worker_2"      id="10" pp="true" />
        <end pd="perf_counters" id="3" />
    </channel>
    <channel>
        <end pd="worker_3"      id="10" pp="true" />
        <end pd="perf_counters" id="4" />
    </channel>
    <channel>
        <end pd="worker_4"      id="10" pp="true" />
        <end pd="perf_counters" id="5" />
    </channel>
    <channel>
        <end pd="worker_5"      id="10" pp="true" />
        <end pd="perf_counters" id="6" />
    </channel>
    <channel>
        <end pd="worker_6"      id="10" pp="true" />
        <end pd="perf_counters" id="7" />
    </channel>
    <channel>
        <end pd="worker_7"      id="10" pp="true" />
        <end pd="perf_counters" id="8" />
    </channel>

    <!--
      ══════════════════════════════════════════════════════════════════
      Console Multiplexer: "tmux for agentOS"

      Passive PD (priority 160) that multiplexes per-PD output streams
      onto the debug UART with attach/detach/switch/broadcast semantics.

      Shared memory: console_rings (64KB = 16 × 4KB per-PD output rings)

      Channels (60-62, after mem_profiler's 50-58):
        60: controller <-> console_mux (PPC: attach/detach/list/mode/status)
        61: init_agent <-> console_mux (notify: init_agent output ready)
        62: event_bus  <-> console_mux (notify: eventbus output ready)
      ══════════════════════════════════════════════════════════════════
    -->

    <!-- Console ring buffer: 16 × 4KB = 64KB shared output rings -->
    <memory_region name="console_rings" size="0x10000" />

    <protection_domain name="console_mux" priority="160" passive="true">
        <program_image path="console_mux.elf" />
        <map mr="console_rings" vaddr="0x9000000" perms="rw" setvar_vaddr="console_rings_vaddr" />
    </protection_domain>

    <!-- Channel 60: controller(id=60) <-> console_mux(id=0) pp=true
         Controller PPCs into console_mux for attach/detach/list/mode commands -->
    <channel>
        <end pd="controller"   id="60" pp="true" />
        <end pd="console_mux"  id="0" />
    </channel>

    <!-- Channel 61: init_agent(id=4) <-> console_mux(id=1)
         init_agent notifies console_mux when it has output to drain -->
    <channel>
        <end pd="init_agent"   id="4" />
        <end pd="console_mux"  id="1" />
    </channel>

    <!-- Channel 62: event_bus(id=60) <-> console_mux(id=2)
         event_bus notifies console_mux on event activity -->
    <channel>
        <end pd="event_bus"    id="60" />
        <end pd="console_mux"  id="2" />
    </channel>

    <!--
      ══════════════════════════════════════════════════════════════════
      Trace Recorder: inter-PD dispatch event logger

      Passive PD (priority 128) that receives best-effort notifications
      from the controller on every inter-PD dispatch (microkit_notify,
      microkit_ppcall).  Useful for debugging sequencing and liveness.

      No shared memory in this stub — a full implementation would map a
      ring buffer here for post-mortem trace dumps.

      Channels (6-7, from controller's perspective):
        6: controller <-> trace_recorder  (pp=true: START/STOP/QUERY/DUMP)
        7: controller -> trace_recorder   (notify on each dispatch event)
      ══════════════════════════════════════════════════════════════════
    -->

    <protection_domain name="trace_recorder" priority="128" passive="true">
        <program_image path="trace_recorder.elf" />
    </protection_domain>

    <!-- Channel 6: controller(id=6) <-> trace_recorder(id=0) pp=true
         Controller PPCs into trace_recorder for START/STOP/QUERY/DUMP -->
    <channel>
        <end pd="controller"       id="6" pp="true" />
        <end pd="trace_recorder"   id="0" />
    </channel>

    <!-- Channel 7: controller(id=7) -> trace_recorder(id=1)
         Controller notifies trace_recorder on each inter-PD dispatch -->
    <channel>
        <end pd="controller"       id="7" />
        <end pd="trace_recorder"   id="1" />
    </channel>

    <!--
      ══════════════════════════════════════════════════════════════════
      Network Isolator: per-agent outbound firewall

      Passive PD (priority 160) that intercepts agent outbound connection
      requests and validates them against per-slot ACL tables.
      Each slot has up to 16 allow rules (hostname:port patterns).
      Denied connections are logged to cap_audit_log.

      Shared memory: net_isolator_ring (256KB): ACL table mirror + stats.

      Channels (63-65):
        63: controller   <-> net_isolator  (pp=true: workers + controller PPC in)
        64: init_agent   <-> net_isolator  (init_agent sets ACLs on spawn)
        65: net_isolator <-> event_bus     (deny events published to bus)
      ══════════════════════════════════════════════════════════════════
    -->

    <!-- net_isolator ring: 256KB ACL + stats shared memory -->
    <memory_region name="net_isolator_ring" size="0x40000" />

    <protection_domain name="net_isolator" priority="160" passive="true">
        <program_image path="net_isolator.elf" />
        <map mr="net_isolator_ring" vaddr="0xA000000" perms="rw" setvar_vaddr="net_isolator_ring_vaddr" />
    </protection_domain>

    <!-- Channel 61: controller(id=61) <-> net_isolator(id=0) pp=true
         Controller and workers PPC into net_isolator for CONNECT/STATUS checks -->
    <channel>
        <end pd="controller"    id="61" pp="true" />
        <end pd="net_isolator"  id="0" />
    </channel>

    <!-- Channel 64: init_agent(id=6) <-> net_isolator(id=1)
         init_agent PPCs into net_isolator to configure per-slot ACLs on spawn
         and clear ACLs on teardown -->
    <channel>
        <end pd="init_agent"    id="6" pp="true" />
        <end pd="net_isolator"  id="1" />
    </channel>

    <!-- Channel 65: net_isolator(id=2) <-> event_bus(id=61)
         net_isolator notifies event_bus on deny events (audit trail) -->
    <channel>
        <end pd="net_isolator"  id="2" />
        <end pd="event_bus"     id="61" />
    </channel>

    <!--
      ══════════════════════════════════════════════════════════════════
      NameServer: runtime service discovery registry (passive, prio 170)

      Replaces hardcoded channel-constant wiring with a named registry.
      Callers PPC in to register, look up, or query service metadata.
      Controller pre-registers all static services at boot.
      SpawnServer (future) will query NameServer when minting capability
      bundles for newly spawned application PDs.

      Channel map (from NameServer's perspective):
        id=0:  controller (pp=true: register + admin)
        id=1:  init_agent (pp=true: lookup during bootstrap)
        id=2:  worker_0   (pp=true: lookup)
        id=3:  worker_1
        id=4:  worker_2
        id=5:  worker_3
        id=6:  worker_4
        id=7:  worker_5
        id=8:  worker_6
        id=9:  worker_7

      Shared memory:
        ns_registry_shmem (8KB): OP_NS_LIST dump buffer
          NameServer writes ns_list_header_t + entries here.
          Controller maps rw (reads after OP_NS_LIST call).
      ══════════════════════════════════════════════════════════════════
    -->

    <memory_region name="ns_registry_shmem" size="0x2000" />  <!-- 8KB list dump -->

    <protection_domain name="nameserver" priority="170" passive="true">
        <program_image path="nameserver.elf" />
        <map mr="ns_registry_shmem" vaddr="0xB000000" perms="rw"
             setvar_vaddr="ns_registry_shmem_vaddr" />
    </protection_domain>

    <!-- Channel 80: controller(id=80, pp=true) <-> nameserver(id=0)
         Controller PPCs into nameserver to register services + admin ops -->
    <channel>
        <end pd="controller"  id="18" pp="true" />
        <end pd="nameserver"  id="0" />
    </channel>

    <!-- Channel 81: init_agent(id=7, pp=true) <-> nameserver(id=1)
         init_agent queries nameserver during agent bootstrap sequence -->
    <channel>
        <end pd="init_agent"  id="7" pp="true" />
        <end pd="nameserver"  id="1" />
    </channel>

    <!-- Channels 82–89: worker_N(id=12, pp=true) <-> nameserver(id=2..9)
         Workers look up services when dispatching agent tasks -->
    <channel>
        <end pd="worker_0"   id="12" pp="true" />
        <end pd="nameserver" id="2" />
    </channel>
    <channel>
        <end pd="worker_1"   id="12" pp="true" />
        <end pd="nameserver" id="3" />
    </channel>
    <channel>
        <end pd="worker_2"   id="12" pp="true" />
        <end pd="nameserver" id="4" />
    </channel>
    <channel>
        <end pd="worker_3"   id="12" pp="true" />
        <end pd="nameserver" id="5" />
    </channel>
    <channel>
        <end pd="worker_4"   id="12" pp="true" />
        <end pd="nameserver" id="6" />
    </channel>
    <channel>
        <end pd="worker_5"   id="12" pp="true" />
        <end pd="nameserver" id="7" />
    </channel>
    <channel>
        <end pd="worker_6"   id="12" pp="true" />
        <end pd="nameserver" id="8" />
    </channel>
    <channel>
        <end pd="worker_7"   id="12" pp="true" />
        <end pd="nameserver" id="9" />
    </channel>

    <!--
      ══════════════════════════════════════════════════════════════════
      SERVICE LAYER: VFS, virtio-blk, SpawnServer, app slots,
                     NetServer, AppManager, HTTP service
      ══════════════════════════════════════════════════════════════════
    -->

    <!-- ── Shared memory regions ──────────────────────────────────────── -->

    <!-- VFS I/O: 128KB — request descriptor + path buffer + data buffer -->
    <memory_region name="vfs_io_shmem"       size="0x20000" />
    <!-- Block DMA: 32KB — DMA buffer shared between vfs_server and virtio_blk -->
    <memory_region name="blk_dma_shmem"      size="0x8000"  />
    <!-- QEMU virt MMIO: virtio-net bus.0 (riscv64: 0x10001000, size 4KB, IRQ 1) -->
    <memory_region name="virtio_net_mmio"    size="0x1000"  phys_addr="0x10001000" />
    <!-- QEMU virt MMIO: virtio-blk bus.1 (riscv64: 0x10002000, size 4KB, IRQ 2) -->
    <memory_region name="virtio_blk_mmio"    size="0x1000"  phys_addr="0x10002000" />
    <!-- ELF staging: 512KB — SpawnServer stages ELF images here -->
    <memory_region name="spawn_elf_shmem"    size="0x80000" />
    <!-- Spawn config: 4KB — app name/path/list area -->
    <memory_region name="spawn_config_shmem" size="0x1000"  />
    <!-- Network packet: 256KB — 16 × 16KB vNIC slots -->
    <memory_region name="net_packet_shmem"   size="0x40000" />
    <!-- App manifest: 16KB — key=value manifests for AppManager -->
    <memory_region name="app_manifest_shmem" size="0x4000"  />
    <!-- HTTP request: 64KB — request header + body for http_svc -->
    <memory_region name="http_req_shmem"     size="0x10000" />

    <!--
      ── virtio-blk: block device driver (passive, prio 175) ──

      Probes QEMU virtio-MMIO at init; returns BLK_ERR_NODEV gracefully
      if no device is present.

      Channels:
        id=0: controller  (pp=true)
        id=1: vfs_server  (pp=true — block I/O requests)
    -->
    <protection_domain name="virtio_blk" priority="175" passive="true">
        <program_image path="virtio_blk.elf" />
        <map mr="blk_dma_shmem"   vaddr="0x5000000" perms="rw"
             setvar_vaddr="blk_dma_shmem_vaddr" />
        <map mr="virtio_blk_mmio" vaddr="0x6000000" perms="rw" cached="false"
             setvar_vaddr="blk_mmio_vaddr" />
    </protection_domain>

    <channel>
        <end pd="controller"  id="22" pp="true" />
        <end pd="virtio_blk"  id="0" />
    </channel>

    <!--
      ── VFS Server: POSIX-flavoured filesystem (passive, prio 155) ──

      MemBackend always available.  BlkBackend wired to virtio_blk via ch 12.

      Channels:
        id=0:  controller      (pp=true)
        id=1:  init_agent      (pp=true)
        id=2..9: worker_0..7   (pp=true)
        id=10: spawn_server    (pp=true — ELF reads)
        id=11: app_manager     (pp=true — manifest reads)
        id=12: virtio_blk      (pp=true OUT — block I/O)
    -->
    <protection_domain name="vfs_server" priority="155" passive="true">
        <program_image path="vfs_server.elf" />
        <map mr="vfs_io_shmem"    vaddr="0x5000000" perms="rw"
             setvar_vaddr="vfs_io_shmem_vaddr" />
        <map mr="blk_dma_shmem"   vaddr="0x6000000" perms="rw"
             setvar_vaddr="blk_dma_shmem_vaddr" />
        <map mr="spawn_elf_shmem" vaddr="0x7000000" perms="rw"
             setvar_vaddr="spawn_elf_shmem_vfs_vaddr" />
    </protection_domain>

    <channel>
        <end pd="controller" id="19" pp="true" />
        <end pd="vfs_server" id="0" />
    </channel>
    <channel>
        <end pd="init_agent"  id="8" pp="true" />
        <end pd="vfs_server"  id="1" />
    </channel>
    <channel>
        <end pd="worker_0"   id="13" pp="true" />
        <end pd="vfs_server" id="2" />
    </channel>
    <channel>
        <end pd="worker_1"   id="13" pp="true" />
        <end pd="vfs_server" id="3" />
    </channel>
    <channel>
        <end pd="worker_2"   id="13" pp="true" />
        <end pd="vfs_server" id="4" />
    </channel>
    <channel>
        <end pd="worker_3"   id="13" pp="true" />
        <end pd="vfs_server" id="5" />
    </channel>
    <channel>
        <end pd="worker_4"   id="13" pp="true" />
        <end pd="vfs_server" id="6" />
    </channel>
    <channel>
        <end pd="worker_5"   id="13" pp="true" />
        <end pd="vfs_server" id="7" />
    </channel>
    <channel>
        <end pd="worker_6"   id="13" pp="true" />
        <end pd="vfs_server" id="8" />
    </channel>
    <channel>
        <end pd="worker_7"   id="13" pp="true" />
        <end pd="vfs_server" id="9" />
    </channel>
    <!-- vfs_server PPCs OUT into virtio_blk for block I/O -->
    <channel>
        <end pd="vfs_server" id="12" pp="true" />
        <end pd="virtio_blk" id="1" />
    </channel>

    <!--
      ── SpawnServer: dynamic application launcher (active, prio 120) ──

      Manages 4 pre-allocated app_slot PDs.  Reads ELF via VFS,
      stages it with a spawn_header_t in spawn_elf_shmem, notifies slot.

      Channels:
        id=0: controller    (pp=true)
        id=1: init_agent    (pp=true)
        id=2: app_manager   (pp=true)
        id=3: vfs_server    (pp=true OUT — ELF reads)
        id=4..7: app_slot_0..3 (notify both ways)
    -->
    <protection_domain name="spawn_server" priority="145">
        <program_image path="spawn_server.elf" />
        <map mr="spawn_elf_shmem"    vaddr="0x5000000" perms="rw"
             setvar_vaddr="spawn_elf_shmem_vaddr" />
        <map mr="spawn_config_shmem" vaddr="0x6000000" perms="rw"
             setvar_vaddr="spawn_config_shmem_vaddr" />
        <map mr="vfs_io_shmem"       vaddr="0x7000000" perms="rw"
             setvar_vaddr="vfs_io_shmem_vaddr" />
    </protection_domain>

    <channel>
        <end pd="controller"   id="20" pp="true" />
        <end pd="spawn_server" id="0" />
    </channel>
    <channel>
        <end pd="init_agent"   id="9" pp="true" />
        <end pd="spawn_server" id="1" />
    </channel>
    <!-- spawn_server PPCs OUT into vfs_server to read ELF files -->
    <channel>
        <end pd="spawn_server" id="3" pp="true" />
        <end pd="vfs_server"   id="10" />
    </channel>

    <!--
      ── App Slots: 4 pre-allocated application PDs (active, prio 70) ──

      All slots share app_slot.elf.  SpawnServer stages an ELF in
      spawn_elf_shmem, writes a spawn_header_t at offset 0, and notifies
      the appropriate slot.  MVP: slot acknowledges immediately.
    -->
    <protection_domain name="app_slot_0" priority="70">
        <program_image path="app_slot.elf" />
        <map mr="spawn_elf_shmem" vaddr="0x5000000" perms="r"
             setvar_vaddr="spawn_elf_shmem_vaddr" />
    </protection_domain>
    <protection_domain name="app_slot_1" priority="70">
        <program_image path="app_slot.elf" />
        <map mr="spawn_elf_shmem" vaddr="0x5000000" perms="r"
             setvar_vaddr="spawn_elf_shmem_vaddr" />
    </protection_domain>
    <protection_domain name="app_slot_2" priority="70">
        <program_image path="app_slot.elf" />
        <map mr="spawn_elf_shmem" vaddr="0x5000000" perms="r"
             setvar_vaddr="spawn_elf_shmem_vaddr" />
    </protection_domain>
    <protection_domain name="app_slot_3" priority="70">
        <program_image path="app_slot.elf" />
        <map mr="spawn_elf_shmem" vaddr="0x5000000" perms="r"
             setvar_vaddr="spawn_elf_shmem_vaddr" />
    </protection_domain>

    <channel>
        <end pd="spawn_server" id="4" />
        <end pd="app_slot_0"   id="0" />
    </channel>
    <channel>
        <end pd="spawn_server" id="5" />
        <end pd="app_slot_1"   id="0" />
    </channel>
    <channel>
        <end pd="spawn_server" id="6" />
        <end pd="app_slot_2"   id="0" />
    </channel>
    <channel>
        <end pd="spawn_server" id="7" />
        <end pd="app_slot_3"   id="0" />
    </channel>

    <!--
      ── NetServer: virtual NIC manager + ACL enforcer (passive, prio 160) ──

      Manages 16 vNICs, virtio-net detection, packet routing.
      smoltcp TCP/IP integration points marked in net_server.c.

      Channels:
        id=0:  controller      (pp=true)
        id=1:  init_agent      (pp=true)
        id=2..9: worker_0..7   (pp=true)
        id=10: app_manager     (pp=true)
    -->
    <protection_domain name="net_server" priority="160" passive="true">
        <program_image path="net_server.elf" />
        <map mr="net_packet_shmem"  vaddr="0x5000000" perms="rw"
             setvar_vaddr="net_packet_shmem_vaddr" />
        <map mr="virtio_net_mmio"   vaddr="0x6000000" perms="rw" cached="false"
             setvar_vaddr="net_mmio_vaddr" />
    </protection_domain>

    <channel>
        <end pd="controller" id="21" pp="true" />
        <end pd="net_server" id="0" />
    </channel>
    <channel>
        <end pd="init_agent"  id="10" pp="true" />
        <end pd="net_server"  id="1" />
    </channel>
    <channel>
        <end pd="worker_0"   id="14" pp="true" />
        <end pd="net_server" id="2" />
    </channel>
    <channel>
        <end pd="worker_1"   id="14" pp="true" />
        <end pd="net_server" id="3" />
    </channel>
    <channel>
        <end pd="worker_2"   id="14" pp="true" />
        <end pd="net_server" id="4" />
    </channel>
    <channel>
        <end pd="worker_3"   id="14" pp="true" />
        <end pd="net_server" id="5" />
    </channel>
    <channel>
        <end pd="worker_4"   id="14" pp="true" />
        <end pd="net_server" id="6" />
    </channel>
    <channel>
        <end pd="worker_5"   id="14" pp="true" />
        <end pd="net_server" id="7" />
    </channel>
    <channel>
        <end pd="worker_6"   id="14" pp="true" />
        <end pd="net_server" id="8" />
    </channel>
    <channel>
        <end pd="worker_7"   id="14" pp="true" />
        <end pd="net_server" id="9" />
    </channel>

    <!--
      ── AppManager: full-stack app orchestrator (active, prio 130) ──

      Parses manifests, creates vNICs, launches ELFs, registers HTTP routes.

      Channels:
        id=0: controller    (pp=true)
        id=1: spawn_server  (OUT — OP_SPAWN_LAUNCH)
        id=2: vfs_server    (OUT — future manifest/config reads)
        id=3: net_server    (OUT — OP_NET_VNIC_CREATE/DESTROY)
        id=4: http_svc      (OUT — OP_HTTP_REGISTER/UNREGISTER)
    -->
    <protection_domain name="app_manager" priority="130">
        <program_image path="app_manager.elf" />
        <map mr="app_manifest_shmem"  vaddr="0x5000000" perms="rw"
             setvar_vaddr="app_manifest_shmem_vaddr" />
        <map mr="spawn_config_shmem"  vaddr="0x8000000" perms="rw"
             setvar_vaddr="spawn_config_shmem_appmgr_vaddr" />
        <map mr="vfs_io_shmem"        vaddr="0x9000000" perms="rw"
             setvar_vaddr="vfs_io_shmem_appmgr_vaddr" />
    </protection_domain>

    <channel>
        <end pd="controller"  id="23" pp="true" />
        <end pd="app_manager" id="0" />
    </channel>
    <!-- app_manager PPCs OUT into spawn_server -->
    <channel>
        <end pd="app_manager"  id="1" pp="true" />
        <end pd="spawn_server" id="2" />
    </channel>
    <!-- app_manager PPCs OUT into vfs_server -->
    <channel>
        <end pd="app_manager" id="2" pp="true" />
        <end pd="vfs_server"  id="11" />
    </channel>
    <!-- app_manager PPCs OUT into net_server -->
    <channel>
        <end pd="app_manager" id="3" pp="true" />
        <end pd="net_server"  id="10" />
    </channel>

    <!--
      ── HTTP Service: route registry + dispatcher (active, prio 140) ──

      Longest-prefix-match handler table.  URL prefixes passed inline in MRs.
      The Rust http-gateway (userspace/servers/http-gateway) calls
      OP_HTTP_DISPATCH to resolve incoming requests.

      Channels:
        id=0: controller   (pp=true — admin + health)
        id=1: app_manager  (pp=true — route register/unregister)
    -->
    <protection_domain name="http_svc" priority="140">
        <program_image path="http_svc.elf" />
        <map mr="http_req_shmem" vaddr="0x5000000" perms="rw"
             setvar_vaddr="http_req_shmem_vaddr" />
    </protection_domain>

    <channel>
        <end pd="controller" id="24" pp="true" />
        <end pd="http_svc"   id="0" />
    </channel>
    <!-- app_manager PPCs OUT into http_svc for route registration -->
    <channel>
        <end pd="app_manager" id="4" pp="true" />
        <end pd="http_svc"    id="1" />
    </channel>
</system>
