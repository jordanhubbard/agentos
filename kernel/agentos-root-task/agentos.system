<?xml version="1.0" encoding="UTF-8"?>
<!--
  agentOS v0.3.0 System Description File
  
  Protection Domain topology:
  
    controller   (prio 50)   - system coordinator + capability broker
    event_bus    (prio 200)  - passive pub/sub server (ring buffer)
    init_agent   (prio 100)  - agent ecosystem bootstrapper
    worker_0..7  (prio 80)   - agent pool workers (dynamic task assignment)
    vibe_engine  (prio 140)  - passive VibeEngine: WASM hot-swap lifecycle
    fault_handler (prio 250) - passive fault catcher: VM/cap fault → ring log + watchdog notify
    debug_bridge (prio 160)  - passive debug channel: live WASM slot debugging via DAP bridge
  
  Channel map:
    0:  controller <-> event_bus    (controller PPCs into passive event_bus)
    1:  controller <-> init_agent   (notify: controller starts init_agent)
    2:  event_bus  <-> init_agent   (init_agent PPCs into event_bus to subscribe)
    5:  controller <-> agentfs      (controller PPCs into passive agentfs)
    6:  agentfs    <-> event_bus    (agentfs notifies on mutations)
    57: controller  <-> cap_audit_log (controller PPCs into passive audit log)
    58: init_agent  <-> cap_audit_log (init_agent PPCs into passive audit log)
    10: controller <-> worker_0     (task assignment + completion notify)
    11: controller <-> worker_1
    12: controller <-> worker_2
    13: controller <-> worker_3
    14: controller <-> worker_4
    15: controller <-> worker_5
    16: controller <-> worker_6
    17: controller <-> worker_7
    
  Worker <-> EventBus channels (workers subscribe to events):
    20: event_bus <-> worker_0
    21: event_bus <-> worker_1
    ...
    27: event_bus <-> worker_7
    30: controller <-> swap_slot_0  (WASM hot-swap)
    31: controller <-> swap_slot_1
    32: controller <-> swap_slot_2
    33: controller <-> swap_slot_3

  VibeEngine channels:
    40: controller <-> vibe_engine  (vibe_engine notifies controller: swap approved)
    41: init_agent <-> vibe_engine  (init_agent PPCs into vibe_engine to propose swaps)
-->
<system>
    <!-- Controller: system coordinator, low priority to PPC into passive servers -->
    <protection_domain name="controller" priority="50">
        <program_image path="controller.elf" />
        <map mr="monitor_stack"  vaddr="0x2000000" perms="rw" setvar_vaddr="monitor_stack_vaddr" />
        <!-- Swap code regions: controller writes WASM images here; swap slot PDs read them -->
        <map mr="swap_code_0" vaddr="0x6000000" perms="rw" setvar_vaddr="swap_code_ctrl_0" />
        <map mr="swap_code_1" vaddr="0x6400000" perms="rw" setvar_vaddr="swap_code_ctrl_1" />
        <map mr="swap_code_2" vaddr="0x6800000" perms="rw" setvar_vaddr="swap_code_ctrl_2" />
        <map mr="swap_code_3" vaddr="0x6C00000" perms="rw" setvar_vaddr="swap_code_ctrl_3" />
        <!-- VibeEngine staging: controller reads WASM proposals from here (r) -->
        <map mr="vibe_staging" vaddr="0x7000000" perms="r" setvar_vaddr="vibe_staging_ctrl_vaddr" />
    </protection_domain>
    
    <!-- EventBus: passive pub/sub backbone -->
    <protection_domain name="event_bus" priority="200" passive="true">
        <program_image path="event_bus.elf" />
        <map mr="eventbus_ring" vaddr="0x3000000" perms="rw" setvar_vaddr="eventbus_ring_vaddr" />
    </protection_domain>
    
    <!-- InitAgent: bootstrap agent -->
    <protection_domain name="init_agent" priority="100">
        <program_image path="init_agent.elf" />
    </protection_domain>
    
    <!-- Agent pool workers: static PDs, dynamic task assignment -->
    <protection_domain name="worker_0" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_1" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_2" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_3" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_4" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_5" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_6" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_7" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    
    <!-- Memory regions -->
    <memory_region name="monitor_stack"  size="0x10000" />
    <memory_region name="eventbus_ring"  size="0x40000" />
    
    <!-- Core service channels -->
    <channel>
        <end pd="controller" id="0" pp="true" />
        <end pd="event_bus"  id="0" />
    </channel>
    <channel>
        <end pd="controller" id="1" />
        <end pd="init_agent" id="1" />
    </channel>
    <channel>
        <end pd="event_bus"  id="2" />
        <end pd="init_agent" id="2" pp="true" />
    </channel>
    
    <!-- Worker pool channels (controller <-> worker_N) -->
    <channel>
        <end pd="controller" id="10" />
        <end pd="worker_0"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="11" />
        <end pd="worker_1"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="12" />
        <end pd="worker_2"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="13" />
        <end pd="worker_3"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="14" />
        <end pd="worker_4"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="15" />
        <end pd="worker_5"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="16" />
        <end pd="worker_6"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="17" />
        <end pd="worker_7"   id="0" />
    </channel>
    
    <!-- AgentFS: passive object store, priority 150 -->
    <!-- Channels: CH0=controller (PPC in), CH1=event_bus (notify out) -->
    <protection_domain name="agentfs" priority="150" passive="true">
        <program_image path="agentfs.elf" />
        <map mr="agentfs_store" vaddr="0x5000000" perms="rw" setvar_vaddr="agentfs_store_vaddr" />
    </protection_domain>

    <!-- Shared memory for AgentFS hot store -->
    <memory_region name="agentfs_store" size="0x50000" />  <!-- 320KB: index + blobs -->

    <!-- Channel 5: controller <-> agentfs (controller PPCs into passive agentfs) -->
    <channel>
        <end pd="controller" id="5" pp="true" />
        <end pd="agentfs"    id="0" />
    </channel>
    <!-- Channel 6: agentfs -> event_bus (agentfs notifies on mutations) -->
    <channel>
        <end pd="agentfs"   id="1" />
        <end pd="event_bus" id="6" />
    </channel>

    <!-- Worker <-> EventBus channels (workers can subscribe to events) -->
    <channel>
        <end pd="event_bus" id="20" />
        <end pd="worker_0"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="21" />
        <end pd="worker_1"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="22" />
        <end pd="worker_2"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="23" />
        <end pd="worker_3"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="24" />
        <end pd="worker_4"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="25" />
        <end pd="worker_5"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="26" />
        <end pd="worker_6"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="27" />
        <end pd="worker_7"  id="1" pp="true" />
    </channel>

    <!--
      Swap slots: 4 pre-allocated PDs for live WASM hot-swap.
      Controller maps each code region rw (writes WASM image + header).
      Swap slot maps it r (reads and interprets via wasm3).
      Channels: controller id=30..33 <-> swap_slot_N id=0
    -->
    <memory_region name="swap_code_0" size="0x400000" />
    <memory_region name="swap_code_1" size="0x400000" />
    <memory_region name="swap_code_2" size="0x400000" />
    <memory_region name="swap_code_3" size="0x400000" />

    <protection_domain name="swap_slot_0" priority="75">
        <program_image path="swap_slot.elf" />
        <map mr="swap_code_0" vaddr="0x2000000" perms="r" setvar_vaddr="swap_code_vaddr" />
    </protection_domain>
    <protection_domain name="swap_slot_1" priority="75">
        <program_image path="swap_slot.elf" />
        <map mr="swap_code_1" vaddr="0x2000000" perms="r" setvar_vaddr="swap_code_vaddr" />
    </protection_domain>
    <protection_domain name="swap_slot_2" priority="75">
        <program_image path="swap_slot.elf" />
        <map mr="swap_code_2" vaddr="0x2000000" perms="r" setvar_vaddr="swap_code_vaddr" />
    </protection_domain>
    <protection_domain name="swap_slot_3" priority="75">
        <program_image path="swap_slot.elf" />
        <map mr="swap_code_3" vaddr="0x2000000" perms="r" setvar_vaddr="swap_code_vaddr" />
    </protection_domain>

    <!-- Channels: controller <-> swap slots -->
    <channel>
        <end pd="controller"  id="30" />
        <end pd="swap_slot_0" id="0" />
    </channel>
    <channel>
        <end pd="controller"  id="31" />
        <end pd="swap_slot_1" id="0" />
    </channel>
    <channel>
        <end pd="controller"  id="32" />
        <end pd="swap_slot_2" id="0" />
    </channel>
    <channel>
        <end pd="controller"  id="33" />
        <end pd="swap_slot_3" id="0" />
    </channel>

    <!--
      VibeEngine: passive hot-swap lifecycle server (priority 140)

      Channels:
        id=0: agents PPC in to propose/validate/execute swaps
        id=1: vibe_engine notifies controller when a swap is approved

      Shared memory:
        vibe_staging (4MB): WASM binary staging area
          - Agents write WASM bytes here before calling OP_VIBE_PROPOSE
          - VibeEngine reads + validates
          - Controller reads and feeds to vibe_swap_begin
    -->
    <memory_region name="vibe_staging" size="0x400000" />  <!-- 4MB staging -->

    <protection_domain name="vibe_engine" priority="140" passive="true">
        <program_image path="vibe_engine.elf" />
        <!-- rw: vibe_engine reads staged WASM and writes metadata footer -->
        <map mr="vibe_staging" vaddr="0x4000000" perms="rw" setvar_vaddr="vibe_staging_vaddr" />
    </protection_domain>

    <!--
      Channel 40: controller(id=40) <-> vibe_engine(id=1)
      vibe_engine notifies controller when a swap proposal is approved.
      Controller wakes up, reads staging metadata, calls vibe_swap_begin.
    -->
    <channel>
        <end pd="controller"   id="40" />
        <end pd="vibe_engine"  id="1" />
    </channel>

    <!--
      Channel 41: init_agent(id=3) <-> vibe_engine(id=0) pp=true
      init_agent can PPC into vibe_engine to propose/validate/execute swaps.
      Used by the demo sequence (Step 4: hot-swap toolsvc with echo_service.wasm).
    -->
    <channel>
        <end pd="init_agent"   id="3" pp="true" />
        <end pd="vibe_engine"  id="0" />
    </channel>

    <!--
      GPU Scheduler PD — priority 120 (PRIO_INTERACTIVE)
      Agents can PPC into gpu_sched to submit/cancel/query GPU tasks.
      gpu_sched notifies controller to dispatch to swap slots.
      gpu_sched publishes GPU_COMPLETE/GPU_FAILED events to EventBus.

      Channel 50: controller(id=50) <-> gpu_sched(id=1)
        controller notifies gpu_sched of slot completion
      Channel 51: event_bus(id=51) <-> gpu_sched(id=2)
        gpu_sched PPCs into event_bus to publish completion events
    -->
    <protection_domain name="gpu_sched" priority="120">
        <program_image path="gpu_sched.elf" />
    </protection_domain>

    <channel>
        <end pd="controller" id="50" />
        <end pd="gpu_sched"  id="1" />
    </channel>

    <channel>
        <end pd="event_bus" id="51" />
        <end pd="gpu_sched" id="2"  pp="true" />
    </channel>

    <!--
      GPU Scheduler (CUDA offload): passive PD (priority 160)
      Manages 4 static CUDA PTX compute slots for WASM modules with
      "agentos.cuda" custom section. VibeEngine notifies on PTX submit.

      Channels:
        id=0: vibe_engine notifies us (OP_GPU_SUBMIT)
        id=1: controller PPCs in to query slot status (OP_GPU_STATUS)
    -->




    <!--
      Distributed Agent Mesh PD - priority 110
      Discovers peer agentOS nodes via SquirrelBus bridge.
      Routes REMOTE_SPAWN requests to least-loaded peer with GPU-affinity.
    -->
    <protection_domain name="mesh_agent" priority="110">
        <program_image path="mesh_agent.elf" />
    </protection_domain>

    <channel>
        <end pd="controller" id="55" />
        <end pd="mesh_agent" id="1" />
    </channel>

    <channel>
        <end pd="event_bus" id="56" />
        <end pd="mesh_agent" id="2" pp="true" />
    </channel>

    <!--
      Capability Audit Log: passive PD (priority 120)
      Records all capability grant/revoke events in a shared-memory ring buffer.
      
      Operations:
        OP_CAP_LOG (0x50)        — append grant/revoke event
        OP_CAP_LOG_STATUS (0x51) — query ring state
        OP_CAP_LOG_DUMP (0x52)   — read entries

      Channels:
        id=0: controller PPCs in (after cap_broker_grant/revoke)
        id=1: init_agent PPCs in (after agent_pool_spawn)
    -->
    <memory_region name="cap_audit_ring" size="0x40000" />  <!-- 256KB ring buffer -->

    <protection_domain name="cap_audit_log" priority="120" passive="true">
        <program_image path="cap_audit_log.elf" />
        <map mr="cap_audit_ring" vaddr="0x8000000" perms="rw" setvar_vaddr="cap_audit_ring_vaddr" />
    </protection_domain>

    <!-- Channel 57: controller(id=57) <-> cap_audit_log(id=0) — controller logs cap events -->
    <channel>
        <end pd="controller"     id="57" pp="true" />
        <end pd="cap_audit_log"  id="0" />
    </channel>

    <!-- Channel 58: init_agent(id=5) <-> cap_audit_log(id=1) — init_agent logs spawn caps -->
    <channel>
        <end pd="init_agent"     id="5" pp="true" />
        <end pd="cap_audit_log"  id="1" />
    </channel>

    <!--
      Fault Handler: passive PD (priority 250 — highest in system)
      Receives seL4 fault endpoint notifications for registered PDs.
      Logs VM faults, cap violations, unknown syscalls, and user exceptions
      to a shared-memory ring buffer. Forwards cap faults to cap_audit_log.
      Notifies controller (watchdog) to trigger PD respawn.

      IPC operations:
        OP_FAULT_STATUS (0x60) — query ring state
        OP_FAULT_DUMP   (0x61) — read recent fault entries
        OP_FAULT_CLEAR  (0x62) — clear ring buffer

      Channels (fault_handler perspective):
        id=0: controller PPCs in (query)
        id=1: init_agent PPCs in (query)
        id=2: fault_handler PPCs out to cap_audit_log (forward cap faults)
        id=3: fault_handler notifies controller (watchdog respawn trigger)
        id=60+: per-PD fault endpoint channels (seL4 fault delivery)
    -->
    <memory_region name="fault_ring" size="0x40000" />  <!-- 256KB fault ring buffer -->

    <protection_domain name="fault_handler" priority="250" passive="true">
        <program_image path="fault_handler.elf" />
        <map mr="fault_ring" vaddr="0x9000000" perms="rw" setvar_vaddr="fault_ring_vaddr" />
    </protection_domain>

    <!-- Channel 59: controller(id=59) <-> fault_handler(id=0) — controller queries fault log -->
    <channel>
        <end pd="controller"      id="59" pp="true" />
        <end pd="fault_handler"   id="0" />
    </channel>

    <!-- Channel 60: init_agent(id=6) <-> fault_handler(id=1) — init_agent queries fault log -->
    <channel>
        <end pd="init_agent"      id="6" pp="true" />
        <end pd="fault_handler"   id="1" />
    </channel>

    <!--
      NOTE: fault_handler (prio 250) cannot PPC into cap_audit_log (prio 120)
      due to seL4 Microkit priority rule. Cap faults are logged in the fault
      ring and controller forwards to cap_audit_log after receiving the
      watchdog notification.
    -->

    <!-- Channel 61: fault_handler(id=2) -> controller(id=60) — watchdog respawn notify -->
    <channel>
        <end pd="fault_handler"   id="2" />
        <end pd="controller"      id="60" />
    </channel>

    <!--
      Debug Bridge: passive PD (priority 100)
      Provides a debug channel for live WASM slot debugging.
      Host-side DAP/GDB tooling attaches to WASM slots, sets breakpoints,
      single-steps, and inspects suspended execution state.

      IPC operations:
        OP_DBG_ATTACH     (0x70) — attach debugger to a WASM slot
        OP_DBG_DETACH     (0x71) — detach debugger from a WASM slot
        OP_DBG_BREAKPOINT (0x72) — set/clear breakpoint at WASM byte offset
        OP_DBG_STEP       (0x73) — single-step a suspended slot
        OP_DBG_STATUS     (0x74) — query debug state / ring status

      Channels (from debug_bridge perspective):
        id=0: vibe_engine PPCs in (debug operations)
        id=1: controller PPCs in (status queries)
        id=2: debug_bridge notifies controller (debug event available)
    -->
    <memory_region name="debug_ring" size="0x40000" />  <!-- 256KB debug event ring -->

    <protection_domain name="debug_bridge" priority="160" passive="true">
        <program_image path="debug_bridge.elf" />
        <map mr="debug_ring" vaddr="0xA000000" perms="rw" setvar_vaddr="debug_ring_vaddr" />
    </protection_domain>

    <!-- Channel 62: vibe_engine(id=3) <-> debug_bridge(id=0) — vibe_engine PPCs into debug_bridge -->
    <channel>
        <end pd="vibe_engine"    id="3" pp="true" />
        <end pd="debug_bridge"   id="0" />
    </channel>

    <!-- Channel 63: controller(id=3) <-> debug_bridge(id=1) — controller PPCs into debug_bridge -->
    <channel>
        <end pd="controller"     id="3" pp="true" />
        <end pd="debug_bridge"   id="1" />
    </channel>

    <!-- Channel 64: debug_bridge(id=2) -> controller(id=4) — debug event notification -->
    <channel>
        <end pd="debug_bridge"   id="2" />
        <end pd="controller"     id="4" />
    </channel>

    <!--
      Quota PD: passive PD (priority 115)
      Enforces per-agent CPU time and memory usage quotas.
      On quota exceeded: notifies controller to revoke caps via cap_broker.

      Operations:
        OP_QUOTA_REGISTER (0x60) — register agent with cpu/mem limits
        OP_QUOTA_TICK     (0x61) — accumulate cpu/mem usage per sched round
        OP_QUOTA_STATUS   (0x62) — query agent quota state
        OP_QUOTA_SET      (0x63) — update quota limits

      Channels (from quota_pd perspective):
        id=0: controller PPCs in (register/tick/status/set)
        id=1: init_agent PPCs in (register on spawn, tick per round)
        id=2: quota_pd -> controller (notify: MSG_QUOTA_REVOKE on exceeded)
    -->
    <memory_region name="quota_ring" size="0x40000" />  <!-- 256KB quota table + event log -->

    <protection_domain name="quota_pd" priority="115" passive="true">
        <program_image path="quota_pd.elf" />
        <map mr="quota_ring" vaddr="0xB000000" perms="rw" setvar_vaddr="quota_ring_vaddr" />
    </protection_domain>

    <!-- Channel: controller(id=52) <-> quota_pd(id=0) — controller manages quotas -->
    <channel>
        <end pd="controller"  id="52" pp="true" />
        <end pd="quota_pd"    id="0" />
    </channel>

    <!-- Channel: init_agent(id=7) <-> quota_pd(id=1) — init_agent registers/ticks quotas -->
    <channel>
        <end pd="init_agent"  id="7" pp="true" />
        <end pd="quota_pd"    id="1" />
    </channel>

    <!-- Channel: quota_pd(id=2) -> controller(id=58) — quota exceeded revocation notify -->
    <channel>
        <end pd="quota_pd"    id="2" />
        <end pd="controller"  id="58" />
    </channel>


    <!-- ═══════════════════════════════════════════════════════════════════
         mem_profiler PD — per-slot WASM heap tracking + leak heuristic
         Priority: 108 (passive, below quota_pd at 115, above bulk workers)

         Opcodes: OP_MP_ALLOC/FREE/SNAPSHOT/RESET (0x80–0x83)
         Channels (from mem_profiler perspective):
           id=0 CH_IN:  controller / init_agent PPCs in (alloc/free/snapshot/reset)
           id=1 CH_OUT: notify watchdog (fault_handler id=4) on leak detection
           id=2 CH_WD:  PPC to watchdog for OP_WD_STATUS (reserved; shares CH_OUT
                        until a dedicated watchdog PD is added)

         Shared memory: 256KB Prometheus-style text ring at 0x80000 in PD vspace.
         Leak heuristic: 100 consecutive OP_MP_ALLOC ticks with
           live_bytes > last_snapshot_bytes → MSG_MEM_LEAK_ALERT to CH_OUT.
    -->
    <memory_region name="mem_profiler_ring" size="0x40000" />  <!-- 256KB Prometheus ring -->

    <protection_domain name="mem_profiler" priority="108" passive="true">
        <program_image path="mem_profiler.elf" />
        <map mr="mem_profiler_ring" vaddr="0x80000" perms="rw" setvar_vaddr="mem_profiler_ring_vaddr" />
    </protection_domain>

    <!-- Channel 65 (logical) / controller id=61: controller <-> mem_profiler(id=0)
         controller (and init_agent via controller relay) PPCs into mem_profiler
         for OP_MP_ALLOC/FREE/SNAPSHOT/RESET operations.
         Note: Microkit caps endpoint ids at 61; logical channel 65 maps here. -->
    <channel>
        <end pd="controller"   id="61" pp="true" />
        <end pd="mem_profiler" id="0" />
    </channel>

    <!-- Channel 66: mem_profiler(id=1) -> fault_handler(id=4)
         mem_profiler notifies watchdog (fault_handler) when a slot's heap has
         grown monotonically for LEAK_TICK_THRESHOLD consecutive alloc ticks.
         fault_handler adds local id=4 as its new endpoint for this channel. -->
    <channel>
        <end pd="mem_profiler"  id="1" />
        <end pd="fault_handler" id="4" />
    </channel>

</system>
