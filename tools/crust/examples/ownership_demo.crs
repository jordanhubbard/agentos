// In hack mode, this runs fine — RC memory keeps everything alive.
// Run with --pedantic=3 (future) to see ownership warnings.

fn greet(name: String) -> String {
    format!("Hello, {}!", name)
}

fn main() {
    let names = vec!["Alice", "Bob", "Charlie"];

    for name in names {
        let greeting = greet(name);
        println!("{}", greeting);
    }

    // In real Rust, `names` would be moved by the for loop above.
    // In hack mode, this is fine — RC keeps it alive.
    let count = 3;
    println!("Greeted {} people", count);

    // String manipulation
    let mut s = String::new();
    s.push_str("Hello");
    s.push_str(", world!");
    println!("{}", s);
    println!("Length: {}", s.len());
    println!("Uppercase: {}", s.to_uppercase());

    // Vec operations
    let mut v = vec![3, 1, 4, 1, 5, 9, 2, 6];
    v.sort();
    println!("Sorted: {:?}", format!("{}", v));
    println!("First: {}", v.get(0));
    println!("Last: {}", v.last());
}
