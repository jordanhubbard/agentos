fn main() {
    let x = 42;
    let name = "world";
    println!("Hello, {}! The answer is {}", name, x);

    let mut numbers = vec![1, 2, 3, 4, 5];
    let mut sum = 0;
    for n in numbers {
        sum = sum + n;
    }
    println!("Sum: {}", sum);

    if sum > 10 {
        println!("Big sum!");
    } else {
        println!("Small sum");
    }

    let mut i = 0;
    while i < 3 {
        println!("i = {}", i);
        i = i + 1;
    }
}
