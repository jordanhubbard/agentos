<?xml version="1.0" encoding="UTF-8"?>
<!--
  agentOS FreeBSD VM Multiplexer — System Description
  
  Runs up to 4 independent FreeBSD AArch64 VM instances under seL4.
  The freebsd_vmm PD manages all slots via the VM multiplexer:
    - OP_VM_CREATE  (0x10): allocate slot and boot FreeBSD
    - OP_VM_DESTROY (0x11): halt and free slot
    - OP_VM_SWITCH  (0x12): switch active console between instances
    - OP_VM_STATUS  (0x13): query all slot states
    - OP_VM_LIST    (0x14): enumerate running instances
  
  Protection Domain topology:
  
    freebsd_vmm  (prio 200) — VM multiplexer (manages 0..4 guests)
    controller   (prio 50)  — agentOS system coordinator
  
  Memory layout:
  
    Shared (read-only in all guests):
      freebsd_flash   0x00000000 - 0x03FFFFFF  64MB  UEFI firmware (EDK2)
  
    Per-slot RAM (each guest sees only its own region):
      freebsd_ram_0   0x40000000 - 0x5FFFFFFF  512MB  VM slot 0
      freebsd_ram_1   0x60000000 - 0x7FFFFFFF  512MB  VM slot 1
      freebsd_ram_2   0x80000000 - 0x9FFFFFFF  512MB  VM slot 2
      freebsd_ram_3   0xa0000000 - 0xBFFFFFFF  512MB  VM slot 3
  
    Passthrough MMIO (shared, all guests see the same physical devices):
      uart            0x09000000               4KB    PL011 UART (console)
      gic_vcpu        0x08040000               4KB    GIC vCPU interface
  
    Note: VirtIO block devices are per-slot (different MMIO addresses per VM).
    In this static description, we configure 4 VirtIO MMIO slots:
      0x0a003000  VM 0 root disk
      0x0a004000  VM 1 root disk
      0x0a005000  VM 2 root disk
      0x0a006000  VM 3 root disk
  
  Channel map:
    70: controller(id=70) ↔ freebsd_vmm(id=0)  lifecycle IPC (pp=true)
    71: freebsd_vmm(id=1) → controller(id=71)  guest events (notify)
  
  Boot:
    freebsd_vmm auto-creates slot 0 on init.
    Slots 1-3 created on demand via controller OP_VM_CREATE IPC.
-->

<system>

    <!-- ═══════════════════════════════════════════════════
         MEMORY REGIONS
         ═══════════════════════════════════════════════════ -->

    <!-- Shared UEFI flash — EDK2 firmware, read-only in all guests -->
    <memory_region name="freebsd_flash"  size="0x4000000" />

    <!-- Per-slot guest RAM: 512MB each -->
    <memory_region name="freebsd_ram_0"  size="0x20000000" />
    <memory_region name="freebsd_ram_1"  size="0x20000000" />
    <memory_region name="freebsd_ram_2"  size="0x20000000" />
    <memory_region name="freebsd_ram_3"  size="0x20000000" />

    <!-- PL011 UART — owned exclusively by serial_pd -->
    <memory_region name="uart"           size="0x1000"  phys_addr="0x9000000" />

    <!-- Shared data buffer: serial_pd ↔ log_drain (256 bytes, one per caller) -->
    <memory_region name="serial_shmem"   size="0x1000" />

    <!-- GIC vCPU interface passthrough (mapped as CPU interface in guest) -->
    <memory_region name="gic_vcpu"       size="0x1000"  phys_addr="0x8040000" />

    <!-- ═══════════════════════════════════════════════════
         PROTECTION DOMAIN: freebsd_vmm
         ═══════════════════════════════════════════════════ -->

    <!--
      serial_pd — generic serial I/O PD.

      Owns the physical PL011 UART exclusively.  All other PDs reach serial
      I/O via MSG_SERIAL_* IPC calls.  Guest VMMs must proxy UART MMIO faults
      from their guests to serial_pd rather than passing through the physical
      device frame.  Priority 180 (above workers; below event_bus).
    -->
    <protection_domain name="serial_pd" priority="180" passive="true">
        <program_image path="serial_pd.elf" />
        <!-- Physical UART MMIO — serial_pd is the sole owner -->
        <map mr="uart"
             vaddr="0x9000000"
             perms="rw"
             setvar_vaddr="uart_mmio_vaddr" />
        <!-- Shared data buffer with log_drain -->
        <map mr="serial_shmem"
             vaddr="0xB000000"
             perms="rw"
             setvar_vaddr="serial_shmem_vaddr" />
    </protection_domain>

    <!--
      log_drain — per-PD log ring buffer drain.

      Drains PD log rings to serial_pd via IPC.  Falls back to
      microkit_dbg_puts if serial_pd is not yet initialized.
      Priority 160 (below serial_pd; above workers).
    -->
    <protection_domain name="log_drain" priority="160" passive="true">
        <program_image path="log_drain.elf" />
        <map mr="serial_shmem"
             vaddr="0xB000000"
             perms="rw"
             setvar_vaddr="serial_shmem_vaddr" />
    </protection_domain>

    <!--
      FreeBSD VM Multiplexer PD.

      Manages 4 independent FreeBSD guests. Each guest has its own:
        - seL4 vCPU (via <virtual_machine> elements below)
        - 512MB RAM region (separate guest physical address space)
        - VirtIO block device backing (for FreeBSD rootfs)

      All guests share:
        - UEFI flash (read-only — EDK2 firmware)
        - GIC vCPU interface (vGIC distributes IRQs per-slot)

      NOTE: Physical UART is no longer passed through to guests.
      freebsd_vmm must emulate UART MMIO faults and proxy via serial_pd IPC.
      (Implementation tracked in Phase 3 guest binding work.)
    -->
    <protection_domain name="freebsd_vmm" priority="200">
        <program_image path="freebsd_vmm.elf" />

        <!-- VMM r/w access to shared UEFI flash (to copy firmware on init) -->
        <map mr="freebsd_flash"
             vaddr="0x10000000"
             perms="rw"
             setvar_vaddr="guest_flash_vaddr" />

        <!-- VMM r/w access to each slot's RAM (to initialise guest state) -->
        <map mr="freebsd_ram_0"
             vaddr="0x40000000"
             perms="rw"
             setvar_vaddr="guest_ram_vaddr_0" />
        <map mr="freebsd_ram_1"
             vaddr="0x60000000"
             perms="rw"
             setvar_vaddr="guest_ram_vaddr_1" />
        <map mr="freebsd_ram_2"
             vaddr="0x80000000"
             perms="rw"
             setvar_vaddr="guest_ram_vaddr_2" />
        <map mr="freebsd_ram_3"
             vaddr="0xa0000000"
             perms="rw"
             setvar_vaddr="guest_ram_vaddr_3" />

        <!-- ─────────────────────────────────────────────
             VM SLOT 0 (auto-started on init)
             ───────────────────────────────────────────── -->
        <virtual_machine name="freebsd-0" id="0">
            <!-- UEFI flash at PA 0x00000000 (EDK2 reset vector) -->
            <map mr="freebsd_flash"  vaddr="0x00000000"  perms="rw" />
            <!-- 512MB RAM at PA 0x40000000 -->
            <map mr="freebsd_ram_0"  vaddr="0x40000000"  perms="rwx" />
            <!-- NOTE: uart removed — serial_pd owns UART exclusively.
                 freebsd_vmm must emulate UART MMIO and proxy via serial_pd. -->
            <!-- GIC CPU interface (vCPU i/f mapped here) -->
            <map mr="gic_vcpu"       vaddr="0x8010000"   perms="rw" />
        </virtual_machine>

        <!-- ─────────────────────────────────────────────
             VM SLOT 1 (created on demand: OP_VM_CREATE)
             ───────────────────────────────────────────── -->
        <virtual_machine name="freebsd-1" id="1">
            <map mr="freebsd_flash"  vaddr="0x00000000"  perms="rw" />
            <map mr="freebsd_ram_1"  vaddr="0x40000000"  perms="rwx" />
            <map mr="gic_vcpu"       vaddr="0x8010000"   perms="rw" />
        </virtual_machine>

        <!-- ─────────────────────────────────────────────
             VM SLOT 2
             ───────────────────────────────────────────── -->
        <virtual_machine name="freebsd-2" id="2">
            <map mr="freebsd_flash"  vaddr="0x00000000"  perms="rw" />
            <map mr="freebsd_ram_2"  vaddr="0x40000000"  perms="rwx" />
            <map mr="gic_vcpu"       vaddr="0x8010000"   perms="rw" />
        </virtual_machine>

        <!-- ─────────────────────────────────────────────
             VM SLOT 3
             ───────────────────────────────────────────── -->
        <virtual_machine name="freebsd-3" id="3">
            <map mr="freebsd_flash"  vaddr="0x00000000"  perms="rw" />
            <map mr="freebsd_ram_3"  vaddr="0x40000000"  perms="rwx" />
            <map mr="gic_vcpu"       vaddr="0x8010000"   perms="rw" />
        </virtual_machine>

    </protection_domain>

    <!-- ═══════════════════════════════════════════════════
         PROTECTION DOMAIN: controller
         ═══════════════════════════════════════════════════ -->

    <!--
      agentOS system controller — sends VM lifecycle IPC to freebsd_vmm.
      In the full agentOS image (agentos.system) this PD coordinates all
      other PDs. Here it provides the VM management interface.
    -->
    <protection_domain name="controller" priority="50">
        <program_image path="controller.elf" />
    </protection_domain>

    <!-- ═══════════════════════════════════════════════════
         CHANNELS
         ═══════════════════════════════════════════════════ -->

    <!--
      Channel 70: controller → freebsd_vmm (pp=true)
      Controller PPCs into VMM to create/destroy/switch VM instances.
      
      IPC operations:
        OP_VM_CREATE  (0x10): mr[0]=0 → returns mr[0]=slot_id
        OP_VM_DESTROY (0x11): mr[0]=slot_id → returns mr[0]=0/1
        OP_VM_SWITCH  (0x12): mr[0]=slot_id → returns mr[0]=0/1
        OP_VM_STATUS  (0x13): → returns mr[0..3]=state per slot
        OP_VM_LIST    (0x14): → returns mr[0]=count, mr[1..N]=id<<8|state
    -->
    <channel>
        <end pd="controller"   id="70" pp="true" />
        <end pd="freebsd_vmm" id="0" />
    </channel>

    <!--
      Channel 71: freebsd_vmm → controller
      VMM notifies controller on guest lifecycle events:
        - Guest booted (slot N reached userspace)
        - Guest halted (ACPI shutdown or power button)
        - Guest faulted (unrecoverable vCPU exception)
      mr[0] = (slot_id << 8) | event_type
    -->
    <channel>
        <end pd="freebsd_vmm" id="1" />
        <end pd="controller"   id="71" />
    </channel>

    <!--
      Channel 67: controller → serial_pd  (CH_SERIAL_PD)
      Controller PPCs serial_pd to open/write/read serial ports.
    -->
    <channel>
        <end pd="controller" id="67" pp="true" />
        <end pd="serial_pd"  id="0" />
    </channel>

    <!--
      Channel: log_drain → serial_pd
      log_drain PPCs serial_pd to write drained log lines.
      Channel 1 on the log_drain side (CH_SERIAL_OUT in log_drain.c).
    -->
    <channel>
        <end pd="log_drain"  id="1" pp="true" />
        <end pd="serial_pd"  id="2" />
    </channel>

</system>
