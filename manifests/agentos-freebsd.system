<?xml version="1.0" encoding="UTF-8"?>
<!--
  agentOS FreeBSD VM Multiplexer — System Description
  
  Runs up to 4 independent FreeBSD AArch64 VM instances under seL4.
  The freebsd_vmm PD manages all slots via the VM multiplexer:
    - OP_VM_CREATE  (0x10): allocate slot and boot FreeBSD
    - OP_VM_DESTROY (0x11): halt and free slot
    - OP_VM_SWITCH  (0x12): switch active console between instances
    - OP_VM_STATUS  (0x13): query all slot states
    - OP_VM_LIST    (0x14): enumerate running instances
  
  Protection Domain topology (Phase 3c — ring-1 consumer model):

    freebsd_vmm  (prio 200) — VM multiplexer; pure ring-1 consumer
    serial_pd    (prio 180) — owns PL011 UART; handles MSG_SERIAL_*
    block_pd     (prio 180) — owns block backend; handles MSG_BLOCK_*
    net_pd       (prio 180) — owns NIC/lwIP; handles MSG_NET_*
    log_drain    (prio 160) — drains PD logs to serial_pd
    controller   (prio  50) — agentOS system coordinator

  freebsd_vmm holds NO direct hardware capabilities after init.
  UART/VirtIO MMIO faults from guests are intercepted and forwarded
  to the appropriate ring-0 service PD via IPC+shmem.

  Memory layout (freebsd_vmm virtual address space):

    0x0C000000   vmm_serial_shmem   1KB   IPC DMA: freebsd_vmm ↔ serial_pd
    0x0D000000   vmm_block_shmem   64KB   IPC DMA: freebsd_vmm ↔ block_pd
    0x0E000000   vmm_net_shmem     64KB   IPC DMA: freebsd_vmm ↔ net_pd
    0x10000000   guest_flash_vaddr 64MB   UEFI firmware (EDK2) — init copy
    0x40000000   guest_ram_vaddr_0 512MB  VM slot 0 RAM
    0x60000000   guest_ram_vaddr_1 512MB  VM slot 1 RAM
    0x80000000   guest_ram_vaddr_2 512MB  VM slot 2 RAM
    0xA0000000   guest_ram_vaddr_3 512MB  VM slot 3 RAM

  Guest IPA layout (each VM sees identical IPA space):

    0x00000000   freebsd_flash  64MB  UEFI firmware (read-only)
    0x08000000   GIC distributor 64KB (vGIC — libvmm managed)
    0x08010000   GIC CPU i/f     4KB  (vCPU interface passthrough)
    0x09000000   PL011 UART      4KB  emulated → serial_pd IPC
    0x0A000000   VirtIO blk[0]   4KB  emulated → block_pd IPC (slot 0)
    0x0A001000   VirtIO blk[1]   4KB  (slot 1)
    0x0A002000   VirtIO blk[2]   4KB  (slot 2)
    0x0A003000   VirtIO blk[3]   4KB  (slot 3)
    0x0A004000   VirtIO net[0]   4KB  emulated → net_pd IPC (slot 0)
    0x0A005000   VirtIO net[1]   4KB  (slot 1)
    0x0A006000   VirtIO net[2]   4KB  (slot 2)
    0x0A007000   VirtIO net[3]   4KB  (slot 3)
    0x40000000   guest RAM      512MB

  Channel map (freebsd_vmm local IDs):
    id=0  CH_VMM_CONTROLLER_PPC — controller → freebsd_vmm  lifecycle IPC
    id=1  CH_VMM_CONTROLLER_EVT — freebsd_vmm → controller  guest events
    id=2  CH_VMM_SERIAL         — freebsd_vmm → serial_pd   UART proxy
    id=3  CH_VMM_NET            — freebsd_vmm → net_pd      VirtIO net
    id=4  CH_VMM_BLOCK          — freebsd_vmm → block_pd    VirtIO blk
    id=5  CH_VMM_KERNEL_LOCAL   — freebsd_vmm → root-task   MSG_VMM_*

  Boot:
    freebsd_vmm auto-creates slot 0 on init (vmm_mux_create → MSG_GUEST_BIND_DEVICE).
    Slots 1-3 created on demand via controller OP_VM_CREATE IPC.
-->

<system>

    <!-- ═══════════════════════════════════════════════════
         MEMORY REGIONS
         ═══════════════════════════════════════════════════ -->

    <!-- Shared UEFI flash — EDK2 firmware, read-only in all guests -->
    <memory_region name="freebsd_flash"  size="0x4000000" />

    <!-- Per-slot guest RAM: 512MB each -->
    <memory_region name="freebsd_ram_0"  size="0x20000000" />
    <memory_region name="freebsd_ram_1"  size="0x20000000" />
    <memory_region name="freebsd_ram_2"  size="0x20000000" />
    <memory_region name="freebsd_ram_3"  size="0x20000000" />

    <!-- PL011 UART — owned exclusively by serial_pd -->
    <memory_region name="uart"           size="0x1000"  phys_addr="0x9000000" />

    <!-- Shared data buffer: serial_pd ↔ log_drain (256 bytes, one per caller) -->
    <memory_region name="serial_shmem"   size="0x1000" />

    <!-- GIC vCPU interface passthrough (mapped as CPU interface in guest) -->
    <memory_region name="gic_vcpu"       size="0x1000"  phys_addr="0x8040000" />

    <!-- IPC shared memory: freebsd_vmm ↔ serial_pd (1KB: short command/response) -->
    <memory_region name="vmm_serial_shmem"  size="0x1000" />

    <!-- IPC shared memory: freebsd_vmm ↔ block_pd (64KB: disk sector DMA) -->
    <memory_region name="vmm_block_shmem"   size="0x10000" />

    <!-- IPC shared memory: freebsd_vmm ↔ net_pd (64KB: Ethernet frame DMA) -->
    <memory_region name="vmm_net_shmem"     size="0x10000" />

    <!-- ═══════════════════════════════════════════════════
         PROTECTION DOMAIN: freebsd_vmm
         ═══════════════════════════════════════════════════ -->

    <!--
      serial_pd — generic serial I/O PD.

      Owns the physical PL011 UART exclusively.  All other PDs reach serial
      I/O via MSG_SERIAL_* IPC calls.  Guest VMMs must proxy UART MMIO faults
      from their guests to serial_pd rather than passing through the physical
      device frame.  Priority 180 (above workers; below event_bus).
    -->
    <protection_domain name="serial_pd" priority="180" passive="true">
        <program_image path="serial_pd.elf" />
        <!-- Physical UART MMIO — serial_pd is the sole owner -->
        <map mr="uart"
             vaddr="0x9000000"
             perms="rw"
             setvar_vaddr="uart_mmio_vaddr" />
        <!-- Shared data buffer with log_drain -->
        <map mr="serial_shmem"
             vaddr="0xB000000"
             perms="rw"
             setvar_vaddr="serial_shmem_vaddr" />
        <!-- IPC DMA buffer shared with freebsd_vmm (ring-1 consumer) -->
        <map mr="vmm_serial_shmem"
             vaddr="0xC000000"
             perms="rw"
             setvar_vaddr="vmm_serial_shmem_vaddr" />
    </protection_domain>

    <!--
      block_pd — OS-neutral block device service PD.

      Owns VirtIO block backend (or host file/device) exclusively.
      Guest VMMs submit MSG_BLOCK_READ / MSG_BLOCK_WRITE via IPC, with
      sector data transferred through vmm_block_shmem.
      Priority 180 (same tier as serial_pd and net_pd).
    -->
    <protection_domain name="block_pd" priority="180" passive="true">
        <program_image path="block_pd.elf" />
        <!-- DMA buffer shared with freebsd_vmm -->
        <map mr="vmm_block_shmem"
             vaddr="0xC000000"
             perms="rw"
             setvar_vaddr="block_shmem_vaddr" />
    </protection_domain>

    <!--
      net_pd — OS-neutral network service PD (lwIP backend).

      Owns the physical NIC (or virtio-net) exclusively.
      Guest VMMs submit MSG_NET_SEND / MSG_NET_RECV via IPC, with
      Ethernet frames transferred through vmm_net_shmem.
      Priority 180.
    -->
    <protection_domain name="net_pd" priority="180" passive="true">
        <program_image path="net_pd.elf" />
        <!-- DMA buffer shared with freebsd_vmm -->
        <map mr="vmm_net_shmem"
             vaddr="0xC000000"
             perms="rw"
             setvar_vaddr="net_shmem_vaddr" />
    </protection_domain>

    <!--
      log_drain — per-PD log ring buffer drain.

      Drains PD log rings to serial_pd via IPC.  Falls back to
      microkit_dbg_puts if serial_pd is not yet initialized.
      Priority 160 (below serial_pd; above workers).
    -->
    <protection_domain name="log_drain" priority="160" passive="true">
        <program_image path="log_drain.elf" />
        <map mr="serial_shmem"
             vaddr="0xB000000"
             perms="rw"
             setvar_vaddr="serial_shmem_vaddr" />
    </protection_domain>

    <!--
      FreeBSD VM Multiplexer PD.

      Manages 4 independent FreeBSD guests. Each guest has its own:
        - seL4 vCPU (via <virtual_machine> elements below)
        - 512MB RAM region (separate guest physical address space)
        - VirtIO block device backing (for FreeBSD rootfs)

      All guests share:
        - UEFI flash (read-only — EDK2 firmware)
        - GIC vCPU interface (vGIC distributes IRQs per-slot)

      NOTE: Physical UART is no longer passed through to guests.
      freebsd_vmm must emulate UART MMIO faults and proxy via serial_pd IPC.
      (Implementation tracked in Phase 3 guest binding work.)
    -->
    <protection_domain name="freebsd_vmm" priority="200">
        <program_image path="freebsd_vmm.elf" />

        <!-- VMM r/w access to shared UEFI flash (to copy firmware on init) -->
        <map mr="freebsd_flash"
             vaddr="0x10000000"
             perms="rw"
             setvar_vaddr="guest_flash_vaddr" />

        <!-- IPC DMA buffers for ring-0 service PD communication -->
        <map mr="vmm_serial_shmem"
             vaddr="0x0C000000"
             perms="rw"
             setvar_vaddr="vmm_serial_shmem_vaddr" />
        <map mr="vmm_block_shmem"
             vaddr="0x0D000000"
             perms="rw"
             setvar_vaddr="vmm_block_shmem_vaddr" />
        <map mr="vmm_net_shmem"
             vaddr="0x0E000000"
             perms="rw"
             setvar_vaddr="vmm_net_shmem_vaddr" />

        <!-- VMM r/w access to each slot's RAM (to initialise guest state) -->
        <map mr="freebsd_ram_0"
             vaddr="0x40000000"
             perms="rw"
             setvar_vaddr="guest_ram_vaddr_0" />
        <map mr="freebsd_ram_1"
             vaddr="0x60000000"
             perms="rw"
             setvar_vaddr="guest_ram_vaddr_1" />
        <map mr="freebsd_ram_2"
             vaddr="0x80000000"
             perms="rw"
             setvar_vaddr="guest_ram_vaddr_2" />
        <map mr="freebsd_ram_3"
             vaddr="0xa0000000"
             perms="rw"
             setvar_vaddr="guest_ram_vaddr_3" />

        <!-- ─────────────────────────────────────────────
             VM SLOT 0 (auto-started on init)
             ───────────────────────────────────────────── -->
        <virtual_machine name="freebsd-0" id="0">
            <!-- UEFI flash at PA 0x00000000 (EDK2 reset vector) -->
            <map mr="freebsd_flash"  vaddr="0x00000000"  perms="rw" />
            <!-- 512MB RAM at PA 0x40000000 -->
            <map mr="freebsd_ram_0"  vaddr="0x40000000"  perms="rwx" />
            <!-- NOTE: uart removed — serial_pd owns UART exclusively.
                 freebsd_vmm must emulate UART MMIO and proxy via serial_pd. -->
            <!-- GIC CPU interface (vCPU i/f mapped here) -->
            <map mr="gic_vcpu"       vaddr="0x8010000"   perms="rw" />
        </virtual_machine>

        <!-- ─────────────────────────────────────────────
             VM SLOT 1 (created on demand: OP_VM_CREATE)
             ───────────────────────────────────────────── -->
        <virtual_machine name="freebsd-1" id="1">
            <map mr="freebsd_flash"  vaddr="0x00000000"  perms="rw" />
            <map mr="freebsd_ram_1"  vaddr="0x40000000"  perms="rwx" />
            <map mr="gic_vcpu"       vaddr="0x8010000"   perms="rw" />
        </virtual_machine>

        <!-- ─────────────────────────────────────────────
             VM SLOT 2
             ───────────────────────────────────────────── -->
        <virtual_machine name="freebsd-2" id="2">
            <map mr="freebsd_flash"  vaddr="0x00000000"  perms="rw" />
            <map mr="freebsd_ram_2"  vaddr="0x40000000"  perms="rwx" />
            <map mr="gic_vcpu"       vaddr="0x8010000"   perms="rw" />
        </virtual_machine>

        <!-- ─────────────────────────────────────────────
             VM SLOT 3
             ───────────────────────────────────────────── -->
        <virtual_machine name="freebsd-3" id="3">
            <map mr="freebsd_flash"  vaddr="0x00000000"  perms="rw" />
            <map mr="freebsd_ram_3"  vaddr="0x40000000"  perms="rwx" />
            <map mr="gic_vcpu"       vaddr="0x8010000"   perms="rw" />
        </virtual_machine>

    </protection_domain>

    <!-- ═══════════════════════════════════════════════════
         PROTECTION DOMAIN: controller
         ═══════════════════════════════════════════════════ -->

    <!--
      agentOS system controller — sends VM lifecycle IPC to freebsd_vmm.
      In the full agentOS image (agentos.system) this PD coordinates all
      other PDs. Here it provides the VM management interface.
    -->
    <protection_domain name="controller" priority="50">
        <program_image path="controller.elf" />
    </protection_domain>

    <!-- ═══════════════════════════════════════════════════
         CHANNELS
         ═══════════════════════════════════════════════════ -->

    <!--
      Channel 70: controller → freebsd_vmm (pp=true)
      Controller PPCs into VMM to create/destroy/switch VM instances.
      
      IPC operations:
        OP_VM_CREATE  (0x10): mr[0]=0 → returns mr[0]=slot_id
        OP_VM_DESTROY (0x11): mr[0]=slot_id → returns mr[0]=0/1
        OP_VM_SWITCH  (0x12): mr[0]=slot_id → returns mr[0]=0/1
        OP_VM_STATUS  (0x13): → returns mr[0..3]=state per slot
        OP_VM_LIST    (0x14): → returns mr[0]=count, mr[1..N]=id<<8|state
    -->
    <channel>
        <end pd="controller"   id="70" pp="true" />
        <end pd="freebsd_vmm" id="0" />
    </channel>

    <!--
      Channel 71: freebsd_vmm → controller
      VMM notifies controller on guest lifecycle events:
        - Guest booted (slot N reached userspace)
        - Guest halted (ACPI shutdown or power button)
        - Guest faulted (unrecoverable vCPU exception)
      mr[0] = (slot_id << 8) | event_type
    -->
    <channel>
        <end pd="freebsd_vmm" id="1" />
        <end pd="controller"   id="71" />
    </channel>

    <!--
      Channel 67: controller → serial_pd  (CH_SERIAL_PD)
      Controller PPCs serial_pd to open/write/read serial ports.
    -->
    <channel>
        <end pd="controller" id="67" pp="true" />
        <end pd="serial_pd"  id="0" />
    </channel>

    <!--
      Channel: log_drain → serial_pd
      log_drain PPCs serial_pd to write drained log lines.
      Channel 1 on the log_drain side (CH_SERIAL_OUT in log_drain.c).
    -->
    <channel>
        <end pd="log_drain"  id="1" pp="true" />
        <end pd="serial_pd"  id="2" />
    </channel>

    <!--
      Channel: freebsd_vmm(id=2) ↔ serial_pd(id=3)  [CH_VMM_SERIAL]
      VMM proxies guest PL011 UART MMIO faults to serial_pd via:
        MSG_SERIAL_OPEN  (0x2001) — open a serial slot for this VM
        MSG_SERIAL_WRITE (0x2002) — forward guest TX byte(s)
        MSG_SERIAL_READ  (0x2003) — poll for pending RX byte(s)
      serial_pd is the callee (pp=true).
    -->
    <channel>
        <end pd="freebsd_vmm" id="2" />
        <end pd="serial_pd"   id="3" pp="true" />
    </channel>

    <!--
      Channel: freebsd_vmm(id=3) ↔ net_pd(id=0)  [CH_VMM_NET]
      VMM proxies guest VirtIO-net MMIO queue notifies to net_pd via:
        MSG_NET_OPEN   (0x3001) — open a net handle for this VM
        MSG_NET_SEND   (0x3002) — submit outbound Ethernet frame via shmem
        MSG_NET_RECV   (0x3003) — poll for inbound Ethernet frame via shmem
      net_pd is the callee (pp=true).
    -->
    <channel>
        <end pd="freebsd_vmm" id="3" />
        <end pd="net_pd"      id="0" pp="true" />
    </channel>

    <!--
      Channel: freebsd_vmm(id=4) ↔ block_pd(id=0)  [CH_VMM_BLOCK]
      VMM proxies guest VirtIO-blk MMIO queue notifies to block_pd via:
        MSG_BLOCK_OPEN  (0x4001) — open a block handle for this VM
        MSG_BLOCK_READ  (0x4002) — read N sectors into shmem
        MSG_BLOCK_WRITE (0x4003) — write N sectors from shmem
        MSG_BLOCK_FLUSH (0x4004) — flush write cache
      block_pd is the callee (pp=true).
    -->
    <channel>
        <end pd="freebsd_vmm" id="4" />
        <end pd="block_pd"    id="0" pp="true" />
    </channel>

    <!--
      CH_VMM_KERNEL_LOCAL (freebsd_vmm id=5) — root-task channel.
      Used for MSG_VMM_REGISTER and MSG_GUEST_BIND_DEVICE calls that
      require root-task (monitor) participation for capability delegation.
      The Microkit monitor does not appear as a named PD in this file;
      in the real build, id=5 is wired to the monitor's receive slot via
      the platform's channel allocation table.
    -->

</system>
