<?xml version="1.0" encoding="UTF-8"?>
<!--
  agentOS System Description — x86_64 + Linux VMM stub

  Extends the base x86_64 system with a linux_vmm Protection Domain.
  On x86_64, linux_vmm is a STUB: libvmm does not yet provide x86_64
  hypervisor support. The PD starts, logs a message, and loops passively.
  It is included so the system manifest can wire channels for future use.

  Define LINUX_VMM_X86_STUB=1 is set at compile time to identify the stub.

  Protection Domain topology:

    controller   (prio 50)   - system coordinator + capability broker
    event_bus    (prio 200)  - passive pub/sub server (ring buffer)
    init_agent   (prio 100)  - agent ecosystem bootstrapper
    worker_0..7  (prio 80)   - agent pool workers (dynamic task assignment)
    vibe_engine  (prio 140)  - passive VibeEngine: WASM hot-swap lifecycle
    agentfs      (prio 150)  - passive content-addressed object store
    swap_slot_0..3 (prio 75) - WASM hot-swap execution slots
    linux_vmm    (prio 254)  - Linux VMM stub (x86_64 — passive, no-op)

  Channel map (native agentOS — same as agentos-x86_64.system):
    0:  controller <-> event_bus    (controller PPCs into passive event_bus)
    1:  controller <-> init_agent   (notify: controller starts init_agent)
    2:  event_bus  <-> init_agent   (init_agent PPCs into event_bus to subscribe)
    5:  controller <-> agentfs      (controller PPCs into passive agentfs)
    6:  agentfs    <-> event_bus    (agentfs notifies on mutations)
    10..17: controller <-> worker_0..7
    20..27: event_bus  <-> worker_0..7
    30..33: controller <-> swap_slot_0..3
    40: controller <-> vibe_engine
    41: init_agent <-> vibe_engine

  Linux VMM stub channel:
    50: controller <-> linux_vmm  (reserved; stub does not process commands)

  x86_64 memory layout (QEMU q35):
    Guest RAM would be at 0x100000000 (4GB) if VMM were implemented.
    Stub does not map any guest RAM — no virtual_machine element needed.
-->
<system>
    <!-- ═══════════════════════════════════════════════════════════════════
         NATIVE agentOS PROTECTION DOMAINS
         ═══════════════════════════════════════════════════════════════════ -->

    <protection_domain name="controller" priority="50">
        <program_image path="controller.elf" />
        <map mr="monitor_stack"  vaddr="0x2000000" perms="rw" setvar_vaddr="monitor_stack_vaddr" />
        <map mr="swap_code_0" vaddr="0x6000000" perms="rw" setvar_vaddr="swap_code_ctrl_0" />
        <map mr="swap_code_1" vaddr="0x6400000" perms="rw" setvar_vaddr="swap_code_ctrl_1" />
        <map mr="swap_code_2" vaddr="0x6800000" perms="rw" setvar_vaddr="swap_code_ctrl_2" />
        <map mr="swap_code_3" vaddr="0x6C00000" perms="rw" setvar_vaddr="swap_code_ctrl_3" />
        <map mr="vibe_staging" vaddr="0x7000000" perms="r"  setvar_vaddr="vibe_staging_ctrl_vaddr" />
    </protection_domain>

    <protection_domain name="event_bus" priority="200" passive="true">
        <program_image path="event_bus.elf" />
        <map mr="eventbus_ring" vaddr="0x3000000" perms="rw" setvar_vaddr="eventbus_ring_vaddr" />
    </protection_domain>

    <protection_domain name="init_agent" priority="100">
        <program_image path="init_agent.elf" />
    </protection_domain>

    <protection_domain name="worker_0" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_1" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_2" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_3" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_4" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_5" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_6" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>
    <protection_domain name="worker_7" priority="80">
        <program_image path="worker.elf" />
    </protection_domain>

    <protection_domain name="agentfs" priority="150" passive="true">
        <program_image path="agentfs.elf" />
        <map mr="agentfs_store" vaddr="0x5000000" perms="rw" setvar_vaddr="agentfs_store_vaddr" />
    </protection_domain>

    <protection_domain name="vibe_engine" priority="140" passive="true">
        <program_image path="vibe_engine.elf" />
        <map mr="vibe_staging" vaddr="0x4000000" perms="rw" setvar_vaddr="vibe_staging_vaddr" />
    </protection_domain>

    <protection_domain name="swap_slot_0" priority="75">
        <program_image path="swap_slot.elf" />
        <map mr="swap_code_0" vaddr="0x2000000" perms="r" setvar_vaddr="swap_code_vaddr" />
    </protection_domain>
    <protection_domain name="swap_slot_1" priority="75">
        <program_image path="swap_slot.elf" />
        <map mr="swap_code_1" vaddr="0x2000000" perms="r" setvar_vaddr="swap_code_vaddr" />
    </protection_domain>
    <protection_domain name="swap_slot_2" priority="75">
        <program_image path="swap_slot.elf" />
        <map mr="swap_code_2" vaddr="0x2000000" perms="r" setvar_vaddr="swap_code_vaddr" />
    </protection_domain>
    <protection_domain name="swap_slot_3" priority="75">
        <program_image path="swap_slot.elf" />
        <map mr="swap_code_3" vaddr="0x2000000" perms="r" setvar_vaddr="swap_code_vaddr" />
    </protection_domain>

    <!--
      serial_pd — generic serial I/O PD.

      On x86_64 the physical UART uses I/O ports (COM1 = 0x3F8), not MMIO.
      uart_mmio_vaddr is not set on this platform; serial_pd operates in
      poll-free / dbg_puts fallback mode.  When x86 MMIO UART support is
      added, map the appropriate physical region and set uart_mmio_vaddr.
    -->
    <protection_domain name="serial_pd" priority="180" passive="true">
        <program_image path="serial_pd.elf" />
        <!-- No uart MMIO on x86 — uart_mmio_vaddr stays 0 -->
        <map mr="serial_shmem"
             vaddr="0xB000000"
             perms="rw"
             setvar_vaddr="serial_shmem_vaddr" />
    </protection_domain>

    <!--
      log_drain — per-PD log ring buffer drain.

      Drains PD log rings to serial_pd via IPC.  Falls back to
      microkit_dbg_puts if serial_pd is not yet initialized.
    -->
    <protection_domain name="log_drain" priority="160" passive="true">
        <program_image path="log_drain.elf" />
        <map mr="serial_shmem"
             vaddr="0xB000000"
             perms="rw"
             setvar_vaddr="serial_shmem_vaddr" />
    </protection_domain>

    <!-- ═══════════════════════════════════════════════════════════════════
         LINUX VMM — x86_64 compliance skeleton (guest_contract.h Phase 3d)

         Priority 254 to match AArch64 linux_vmm placement.
         On x86_64, libvmm does not yet provide VMX hypervisor support.
         The PD starts, logs "x86_64 not yet supported", and loops passively.

         guest_contract.h compliance skeleton is present in linux_vmm.c:
           - linux_vmm_contract.h included (vmm_contract.h + guest_contract.h)
           - Binding protocol stubs for MSG_VMM_REGISTER, MSG_SERIAL_OPEN,
             MSG_GUEST_BIND_DEVICE, and EVENT_GUEST_READY are in place.

         CPL3 Enforcement Requirement (x86_64):
           When x86_64 VMM support is added, Linux guest vCPUs MUST operate in
           VMX non-root mode with EPT (Extended Page Tables) active.  The guest
           kernel runs at guest CPL 0 (non-root) — it MUST NOT access host CPL 0.
           VMEXITs must be handled for: CPUID, MSR read/write, I/O port access,
           EPT violations, and all hardware MMIO accesses.  Physical devices
           (UART, NIC, disk) must be accessed via service PDs through
           MSG_GUEST_BIND_DEVICE — never via direct MMIO passthrough to the guest.

         Channel 50: controller bridge (active when VMM is implemented).
         Channel 51: reserved for linux_vmm → serial_pd UART proxy.
                     Wire to serial_pd when x86_64 VMM support is added.
         ═══════════════════════════════════════════════════════════════════ -->
    <protection_domain name="linux_vmm" priority="254">
        <program_image path="linux_vmm.elf" />
    </protection_domain>

    <!-- ═══════════════════════════════════════════════════════════════════
         MEMORY REGIONS
         ═══════════════════════════════════════════════════════════════════ -->
    <memory_region name="monitor_stack"  size="0x10000" />
    <memory_region name="eventbus_ring"  size="0x40000" />
    <memory_region name="agentfs_store"  size="0x50000" />
    <memory_region name="swap_code_0"    size="0x400000" />
    <memory_region name="swap_code_1"    size="0x400000" />
    <memory_region name="swap_code_2"    size="0x400000" />
    <memory_region name="swap_code_3"    size="0x400000" />
    <memory_region name="vibe_staging"   size="0x400000" />
    <!-- Shared data buffer: serial_pd ↔ log_drain (256-byte I/O window) -->
    <memory_region name="serial_shmem"   size="0x1000" />

    <!-- ═══════════════════════════════════════════════════════════════════
         CHANNELS
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- Core service channels -->
    <channel>
        <end pd="controller" id="0" pp="true" />
        <end pd="event_bus"  id="0" />
    </channel>
    <channel>
        <end pd="controller" id="1" />
        <end pd="init_agent" id="1" />
    </channel>
    <channel>
        <end pd="event_bus"  id="2" />
        <end pd="init_agent" id="2" pp="true" />
    </channel>

    <!-- Controller <-> AgentFS -->
    <channel>
        <end pd="controller" id="5" pp="true" />
        <end pd="agentfs"    id="0" />
    </channel>
    <channel>
        <end pd="agentfs"   id="1" />
        <end pd="event_bus" id="6" />
    </channel>

    <!-- Worker pool channels -->
    <channel>
        <end pd="controller" id="10" />
        <end pd="worker_0"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="11" />
        <end pd="worker_1"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="12" />
        <end pd="worker_2"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="13" />
        <end pd="worker_3"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="14" />
        <end pd="worker_4"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="15" />
        <end pd="worker_5"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="16" />
        <end pd="worker_6"   id="0" />
    </channel>
    <channel>
        <end pd="controller" id="17" />
        <end pd="worker_7"   id="0" />
    </channel>

    <!-- Worker <-> EventBus channels -->
    <channel>
        <end pd="event_bus" id="20" />
        <end pd="worker_0"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="21" />
        <end pd="worker_1"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="22" />
        <end pd="worker_2"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="23" />
        <end pd="worker_3"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="24" />
        <end pd="worker_4"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="25" />
        <end pd="worker_5"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="26" />
        <end pd="worker_6"  id="1" pp="true" />
    </channel>
    <channel>
        <end pd="event_bus" id="27" />
        <end pd="worker_7"  id="1" pp="true" />
    </channel>

    <!-- Swap slot channels -->
    <channel>
        <end pd="controller"  id="30" />
        <end pd="swap_slot_0" id="0" />
    </channel>
    <channel>
        <end pd="controller"  id="31" />
        <end pd="swap_slot_1" id="0" />
    </channel>
    <channel>
        <end pd="controller"  id="32" />
        <end pd="swap_slot_2" id="0" />
    </channel>
    <channel>
        <end pd="controller"  id="33" />
        <end pd="swap_slot_3" id="0" />
    </channel>

    <!-- VibeEngine channels -->
    <channel>
        <end pd="controller"   id="40" />
        <end pd="vibe_engine"  id="1" />
    </channel>
    <channel>
        <end pd="init_agent"   id="3" pp="true" />
        <end pd="vibe_engine"  id="0" />
    </channel>

    <!--
      Channel 50: controller <-> linux_vmm (bridge; stub does not process messages).
      Channel 51 (future): linux_vmm → serial_pd UART proxy — wire when x86_64
                           VMM support is added to libvmm (CPL3 enforcement required).
    -->
    <channel>
        <end pd="controller" id="50" />
        <end pd="linux_vmm"  id="2" />
    </channel>

    <!-- ═══════════════════════════════════════════════════════════════════
         USB HOST CONTROLLER PD — QEMU Q35 xhci-pci emulation

         QEMU Q35 xhci-pci device: add -device qemu-xhci,id=usb,addr=0x03
         to the QEMU command line.  BAR0 is at 0xfe900000 on the Q35 PCIe
         bus when slot 3 is used.

         Build with: make build AGENTOS_USB_PD=1 ARCH_X86_64=1

         usb_pd exposes MSG_USB_ENUMERATE/LIST/OPEN/CLOSE/CONTROL/BULK_IN/
         BULK_OUT/STATUS on channel 70 (CH_USB_PD from controller perspective).

         Device class filtering policy is passed as MR2 on MSG_USB_OPEN:
           USB_POLICY_HID     (1<<0) — keyboard/mouse passthrough
           USB_POLICY_STORAGE (1<<1) — mass storage passthrough
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- QEMU Q35 xhci-pci BAR0: 0xfe900000 (Q35 PCIe slot 3, QEMU default).
         Update phys_addr if your QEMU command line places XHCI at a different
         BAR address.  Use `info pci` in the QEMU monitor to confirm. -->
    <memory_region name="usb_xhci_mmio" size="0x1000" phys_addr="0xfe900000" />

    <!-- Shared data region: usb_dev_info_t[] device list + transfer buffers.
         64KB accommodates USB_MAX_DEVICES (32) usb_dev_info_t entries plus
         transfer staging area for bulk/control data. -->
    <memory_region name="usb_shmem" size="0x10000" />

    <protection_domain name="usb_pd" priority="175" passive="true">
        <program_image path="usb_pd.elf" />
        <!-- XHCI MMIO window — uncached, device I/O -->
        <map mr="usb_xhci_mmio" vaddr="0x12000000" perms="rw" cached="false"
             setvar_vaddr="usb_mmio_vaddr" />
        <!-- Shared shmem: device list + transfer data (rw for usb_pd) -->
        <map mr="usb_shmem" vaddr="0x12100000" perms="rw"
             setvar_vaddr="usb_shmem_vaddr" />
    </protection_domain>

    <!-- Controller maps usb_shmem read-only for device list inspection -->
    <!-- To enable: add to controller PD:
         <map mr="usb_shmem" vaddr="0x13000000" perms="r"
              setvar_vaddr="usb_shmem_ctrl_vaddr" /> -->

    <!-- CH_USB_PD = 70: controller PPCs into usb_pd -->
    <channel>
        <end pd="controller" id="70" pp="true" />
        <end pd="usb_pd"     id="0" />
    </channel>

    <!--
      Channel 67: controller → serial_pd  (CH_SERIAL_PD)
      Controller PPCs serial_pd to open/write/read serial ports.
    -->
    <channel>
        <end pd="controller" id="67" pp="true" />
        <end pd="serial_pd"  id="0" />
    </channel>

    <!--
      Channel: log_drain → serial_pd
      log_drain PPCs serial_pd to write drained log lines.
      Channel 1 on the log_drain side (CH_SERIAL_OUT in log_drain.c).
    -->
    <channel>
        <end pd="log_drain"  id="1" pp="true" />
        <end pd="serial_pd"  id="2" />
    </channel>

</system>
